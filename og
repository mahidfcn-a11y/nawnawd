-- FARMING LOOP
-- ============================================================
local function stopAndReturn()
    if ST.stopping then return end
    ST.stopping          = true
    ST.running           = false
    ST.autoTrialEnabled  = false
    ST.autoTrialRunning  = false
    ST.trialInProgress   = false
    ST.trialCollecting   = false
    -- clear farming/tower tweens but NOT returnTweenToken — doTweenReturn manages that itself
    ST.activeTweenToken = nil
    ST.towerTweenToken  = nil
    ST.tweening         = false
    stopContinuousTracker(); resetTracker(); restoreSelections()
    if LBL.Status then LBL.Status.Text = "Returning..." end
    startBtn.Text = "↩ RETURNING..."; startBtn.BackgroundColor3 = Color3.fromRGB(200,130,0)

    local function finishReturn()
        ST.stopping = false
        unlockPhysics(); disableNoclip(); restoreFloors(); updateFloorLabel()
        startBtn.Text = "▶ START"; startBtn.BackgroundColor3 = Color3.fromRGB(40,140,40)
        if LBL.Status then LBL.Status.Text = "Stopped" end
        if LBL.Phase  then LBL.Phase.Text  = "--" end
        if LBL.Speed  then LBL.Speed.Text  = "" end
    end

    task.spawn(function()
        -- wait two frames so cleared tokens propagate
        RunService.Heartbeat:Wait()
        RunService.Heartbeat:Wait()

        -- wait until alive
        local dw = 0
        while not isAlive() and dw < 10 do task.wait(0.3); dw += 0.3 end
        if not isAlive() then finishReturn(); return end

        if not ST.savedCFrame then
            finishReturn(); return
        end

        enableNoclip(); lockPhysics()
        refreshChar()

        local savedPos = ST.savedCFrame.Position
        local myPos    = rootPart.Position

        -- Phase 1: dive underground from current position
        if LBL.Phase then LBL.Phase.Text = "↓ Returning..." end
        local ok1 = doTweenReturn(
            CFrame.new(myPos.X, myPos.Y + CFG.TRAVEL_DEPTH, myPos.Z),
            CFG.DIVE_SPEED, 2
        )
        if not ok1 then
            -- tween was interrupted (e.g. died mid-dive) — still try to finish
            if not isAlive() then finishReturn(); return end
        end

        -- Phase 2: travel horizontally underground to saved XZ
        if LBL.Phase then LBL.Phase.Text = "→ Returning..." end
        local curY = rootPart.Position.Y
        local ok2 = doTweenReturn(
            CFrame.new(savedPos.X, curY, savedPos.Z),
            CFG.TWEEN_SPEED, 0
        )
        if not ok2 then
            if not isAlive() then finishReturn(); return end
        end

        -- Phase 3: wave check before rising
        if ST.waveCheckEnabled then
            local wt = tick()
            while isWaveNear(savedPos, CFG.WAVE_SAFE_DISTANCE) and tick()-wt < CFG.WAVE_MAX_WAIT do
                if LBL.Phase then LBL.Phase.Text = "↑ Waiting for wave..." end
                task.wait(CFG.WAVE_CHECK_INTERVAL)
            end
        end

        -- Phase 4: rise up to saved position
        if LBL.Phase then LBL.Phase.Text = "↑ Returning..." end
        doTweenReturn(ST.savedCFrame, CFG.RISE_SPEED, 2)

        finishReturn()
    end)
end

local function startFarming()
    if ST.running then return end; ST.running=true; ST.farmingTab=ST.activeSubTab
    if not ST.savedCFrame and rootPart and rootPart.Parent then ST.savedCFrame=rootPart.CFrame; updateSavedPosLabel() end
    enableNoclip(); lockPhysics(); clearFloors(); updateFloorLabel()
    if LBL.Status then LBL.Status.Text="Running..." end
    startBtn.Text="⏹ STOP"; startBtn.BackgroundColor3=Color3.fromRGB(60,60,140)
    task.spawn(function()
        refreshChar()
        if isAlive() and rootPart.Position.Y > CFG.TRAVEL_DEPTH + 10 then
            if LBL.Phase then LBL.Phase.Text="↓ Initial dive..." end
            doTween(CFrame.new(rootPart.Position.X, rootPart.Position.Y + CFG.TRAVEL_DEPTH, rootPart.Position.Z), CFG.DIVE_SPEED, 2, false)
        end
        while ST.running do
            if not isAlive() then if LBL.Status then LBL.Status.Text="Dead - waiting..." end; task.wait(0.5); continue end
            if ST.trialInProgress or ST.trialCollecting then task.wait(0.5); continue end
            if not ST.running then break end
            refreshChar(); checkMapChange()
            if not hasSelections() then if LBL.Status then LBL.Status.Text="No rarity selected!" end; task.wait(1); continue end
            local targets=getTargetsSorted()
            if #targets==0 then if LBL.Status then LBL.Status.Text="No targets..." end; task.wait(0.8); continue end
            for _,target in ipairs(targets) do
                if not ST.running then break end
                if not isAlive() then break end
                if not target.Part or not target.Part.Parent or not target.Object or not target.Object.Parent then continue end
                refreshChar(); local tp=target.Part.CFrame.Position
                if LBL.Status then LBL.Status.Text="["..target.Rarity.."] "..target.Name end
                smartTravelTo(tp, CFG.GRAB_HEIGHT, false, false)
                if not ST.running or not isAlive() then break end
                if ST.waveCheckEnabled and isWaveNear(rootPart.Position, CFG.WAVE_SAFE_DISTANCE * 0.5) then
                    doTween(CFrame.new(rootPart.Position.X, rootPart.Position.Y + CFG.TRAVEL_DEPTH, rootPart.Position.Z), CFG.DIVE_SPEED * 2, 0, false)
                    task.wait(0.3); continue
                end
                if not target.Part or not target.Part.Parent then continue end
                if LBL.Phase then LBL.Phase.Text="Grabbing!" end
                fullGrab(target.Object, target.Part, tp)
                ST.totalGrabbed += 1
                if LBL.Grabbed then LBL.Grabbed.Text="Grabbed: "..ST.totalGrabbed end
                if LBL.Log then LBL.Log.Text="["..target.Rarity.."] "..target.Name end
                task.wait(CFG.WAIT_AT_TARGET)
                if not ST.running then break end
                if not isAlive() then break end
                if LBL.Phase then LBL.Phase.Text="↓ Diving..." end
                refreshChar()
                doTween(CFrame.new(rootPart.Position.X, rootPart.Position.Y + CFG.TRAVEL_DEPTH, rootPart.Position.Z), CFG.DIVE_SPEED, 2, false)
            end
            if not ST.running then break end
            if not CFG.AUTO_LOOP then ST.running=false; break end
            task.wait(0.2)
        end
        if not ST.autoTrialRunning and not ST.stopping then
            restoreFloors(); updateFloorLabel(); unlockPhysics(); disableNoclip()
            startBtn.Text="▶ START"; startBtn.BackgroundColor3=Color3.fromRGB(40,140,40)
            if LBL.Status then LBL.Status.Text="Stopped" end
            if LBL.Phase then LBL.Phase.Text="--" end
        end
    end)
end

