do
    function Fn.FindMyBase()
        if State.MyBase and State.MyBase.Parent then return State.MyBase end
        local bf=workspace:FindFirstChild("Bases"); if not bf then return nil end
        local char=LP.Character; if not char then return nil end
        local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return nil end
        local best,bd=nil,math.huge
        for _,base in ipairs(bf:GetChildren()) do
            for _,p in ipairs(base:GetDescendants()) do
                if p:IsA("BasePart") then
                    local d=(hrp.Position-p.Position).Magnitude
                    if d<bd then bd=d best=base end
                end
            end
        end
        State.MyBase=best; return best
    end

    local function CollectSlots()
        if not State.MyBase or not State.MyBase.Parent then return end
        local char=LP.Character; if not char then return end
        local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        local search=State.MyBase:FindFirstChild("Slots") or State.MyBase
        for _,d in ipairs(search:GetDescendants()) do
            if d:IsA("BasePart") and d:FindFirstChild("TouchInterest") then
                pcall(function()
                    if firetouchinterest then firetouchinterest(hrp,d,0) firetouchinterest(hrp,d,1) end
                end)
            end
        end
        State.MoneyCollectCount=State.MoneyCollectCount+1
    end

    task.spawn(function() while true do if State.AutoCollect and State.MyBase then pcall(CollectSlots) end task.wait(State.AutoCollectSpeed) end end)
    task.spawn(function() while true do if State.AutoRebirth then pcall(function() local r=game:GetService("ReplicatedStorage").RemoteFunctions.Rebirth:InvokeServer() if r then State.RebirthCount=State.RebirthCount+1 end end) end task.wait(State.RebirthSpeed) end end)
    task.spawn(function() while true do if State.AutoUpgrade1 then pcall(function() game:GetService("ReplicatedStorage").RemoteFunctions.UpgradeSpeed:InvokeServer(1) State.Upgrade1Count=State.Upgrade1Count+1 end) end task.wait(State.UpgradeSpeed) end end)
    task.spawn(function() while true do if State.AutoUpgrade10 then pcall(function() game:GetService("ReplicatedStorage").RemoteFunctions.UpgradeSpeed:InvokeServer(10) State.Upgrade10Count=State.Upgrade10Count+1 end) end task.wait(State.UpgradeSpeed) end end)
    task.spawn(function() while true do if State.AutoUpgradeBase then pcall(function() game:GetService("ReplicatedStorage").Shared.Remotes.Networking["RE/Plots/PlotUpgradeBase"]:FireServer() State.UpgradeBaseCount=State.UpgradeBaseCount+1 end) end task.wait(State.UpgradeBaseSpeed) end end)
end

-- ════════════════════════════════════════
-- // COIN SCANNER
-- ════════════════════════════════════════
do
    local function CreateScannerVisuals()
        for _,p in pairs(State.ScannerParts) do if p and p.Parent then p:Destroy() end end
        State.ScannerParts={}
        local function mkP(name,color,size)
            local p=Instance.new("Part") p.Name=name p.Shape=Enum.PartType.Cylinder
            p.Size=size or Vector3.new(0.5,State.ScanRadius*2,State.ScanRadius*2)
            p.Anchored=true p.CanCollide=false p.Transparency=0.85
            p.Color=color p.Material=Enum.Material.Neon p.CastShadow=false p.Parent=workspace
            table.insert(State.ScannerParts,p) return p
        end
        local scanner=mkP("CoinScanner_Main",C.Cyan)
        local sl=Instance.new("Part") sl.Name="CoinScanner_Line" sl.Size=Vector3.new(State.ScanRadius,0.4,0.4) sl.Anchored=true sl.CanCollide=false sl.Transparency=0.3 sl.Color=C.Gold sl.Material=Enum.Material.Neon sl.CastShadow=false sl.Parent=workspace table.insert(State.ScannerParts,sl)
        local sl2=Instance.new("Part") sl2.Name="CoinScanner_Line2" sl2.Size=Vector3.new(State.ScanRadius,0.3,0.3) sl2.Anchored=true sl2.CanCollide=false sl2.Transparency=0.5 sl2.Color=C.Green sl2.Material=Enum.Material.Neon sl2.CastShadow=false sl2.Parent=workspace table.insert(State.ScannerParts,sl2)
        return scanner,sl,sl2
    end
    local function DestroyScannerVisuals()
        for _,p in pairs(State.ScannerParts) do if p and p.Parent then p:Destroy() end end State.ScannerParts={}
    end
    local function CollectCoinPart(part,hrp,coinType)
        pcall(function()
            if part:FindFirstChild("TouchInterest") then
                firetouchinterest(hrp,part,0) task.wait() firetouchinterest(hrp,part,1)
                State.TotalCoinsCollected=State.TotalCoinsCollected+1
                if coinType=="radioactive" then State.RadioactiveCollected=State.RadioactiveCollected+1
                elseif coinType=="doom" then State.DoomCollected=State.DoomCollected+1 end
                return
            end
            for _,c in pairs(part:GetDescendants()) do
                if c:IsA("TouchTransmitter") or c.Name=="TouchInterest" then
                    firetouchinterest(hrp,c.Parent,0) task.wait() firetouchinterest(hrp,c.Parent,1)
                    State.TotalCoinsCollected=State.TotalCoinsCollected+1
                    if coinType=="radioactive" then State.RadioactiveCollected=State.RadioactiveCollected+1
                    elseif coinType=="doom" then State.DoomCollected=State.DoomCollected+1 end
                    return
                end
            end
        end)
    end
    local function ScanCoins(hrp)
        local rp=hrp.Position
        local ep=workspace:FindFirstChild("EventParts")
        if ep then
            local rf=ep:FindFirstChild("RadioactiveCoinsFolder")
            if rf then for _,coin in pairs(rf:GetChildren()) do local cp=coin:IsA("BasePart") and coin or (coin:IsA("Model") and (coin.PrimaryPart or coin:FindFirstChildWhichIsA("BasePart"))) if cp then local ok,d=pcall(function() return (cp.Position-rp).Magnitude end) if ok and d<=State.ScanRadius then CollectCoinPart(cp,hrp,"radioactive") end end end end
        end
        local dp=workspace:FindFirstChild("DoomEventParts")
        if dp then for _,o in pairs(dp:GetDescendants()) do if o:IsA("BasePart") then local ok,d=pcall(function() return (o.Position-rp).Magnitude end) if ok and d<=State.ScanRadius and (o:FindFirstChild("TouchInterest") or o.Name:lower():find("coin") or o.Name:lower():find("token")) then CollectCoinPart(o,hrp,"doom") end end end end
    end
    function Fn.StartCoinScanner()
        if State.scannerConnection then return end
        local scanner,sl,sl2=CreateScannerVisuals()
        State.scannerConnection=RunService.RenderStepped:Connect(function(dt)
            if not State.AutoCoinScan then DestroyScannerVisuals() if State.scannerConnection then State.scannerConnection:Disconnect() State.scannerConnection=nil end return end
            local char=LP.Character; if not char then return end
            local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
            if not scanner or not scanner.Parent then scanner,sl,sl2=CreateScannerVisuals() end
            local rp=hrp.Position local rc=CFrame.new(rp)
            State.scanAngle=State.scanAngle+(dt*State.ScanSpeed*math.pi*2)
            State.pulseTime=State.pulseTime+dt
            local pulse=math.sin(State.pulseTime*3)*0.08+0.92
            if scanner and scanner.Parent then scanner.CFrame=rc*CFrame.Angles(0,0,math.rad(90)) scanner.Size=Vector3.new(0.5,State.ScanRadius*2*pulse,State.ScanRadius*2*pulse) scanner.Color=Color3.fromHSV((State.pulseTime*0.1)%1,0.8,1) end
            if sl and sl.Parent then sl.CFrame=rc*CFrame.Angles(0,State.scanAngle,0)*CFrame.new(State.ScanRadius/2,0,0) end
            if sl2 and sl2.Parent then sl2.CFrame=rc*CFrame.Angles(0,State.scanAngle+math.pi,0)*CFrame.new(State.ScanRadius/2,0,0) end
        end)
    end
    function Fn.StopCoinScanner()
        if State.scannerConnection then State.scannerConnection:Disconnect() State.scannerConnection=nil end
        DestroyScannerVisuals()
    end
    task.spawn(function() while true do if State.AutoCoinScan then local char=LP.Character if char then local hrp=char:FindFirstChild("HumanoidRootPart") if hrp then pcall(function() ScanCoins(hrp) end) end end end task.wait(0.15) end end)
end

-- ════════════════════════════════════════
-- // INSTANT GRAB
-- ════════════════════════════════════════
do
    local function fixBrainrots()
        local ab=workspace:FindFirstChild("ActiveBrainrots"); if not ab then return 0 end
        local count=0
        for _,r in pairs(ab:GetChildren()) do for _,b in pairs(r:GetChildren()) do local root=b:FindFirstChild("Root") if root then local tp=root:FindFirstChild("TakePrompt") if tp and tp:IsA("ProximityPrompt") and tp.HoldDuration>0 then tp.HoldDuration=0 count=count+1 end end end end
        State.BrainrotsFixed=State.BrainrotsFixed+count; return count
    end
    function Fn.startInstantGrab()
        fixBrainrots()
        local ab=workspace:FindFirstChild("ActiveBrainrots")
        if ab then State.GrabConnection=ab.DescendantAdded:Connect(function(d) if State.InstantGrabEnabled and d:IsA("ProximityPrompt") and d.Name=="TakePrompt" then task.wait() d.HoldDuration=0 State.BrainrotsFixed=State.BrainrotsFixed+1 end end) end
        task.spawn(function() while State.InstantGrabEnabled do pcall(fixBrainrots) task.wait(2) end end)
    end
    function Fn.stopInstantGrab()
        if State.GrabConnection then State.GrabConnection:Disconnect() State.GrabConnection=nil end
    end
    local function fixLuckyBlocks()
        local alb=workspace:FindFirstChild("ActiveLuckyBlocks"); if not alb then return 0 end
        local count=0
        for _,lb in pairs(alb:GetDescendants()) do if lb:IsA("Model") then local rp=lb:FindFirstChild("RootPart") if rp then local pp=rp:FindFirstChild("ProximityPrompt") if pp and pp:IsA("ProximityPrompt") and pp.HoldDuration>0 then pp.HoldDuration=0 count=count+1 end end end end
        State.LuckyBlocksFixed=State.LuckyBlocksFixed+count; return count
    end
    function Fn.startInstantLuckyBlock()
        fixLuckyBlocks()
        local alb=workspace:FindFirstChild("ActiveLuckyBlocks")
        if alb then State.LuckyBlockConnection=alb.DescendantAdded:Connect(function(d) if State.InstantLuckyBlockEnabled and d:IsA("ProximityPrompt") then task.wait() d.HoldDuration=0 State.LuckyBlocksFixed=State.LuckyBlocksFixed+1 end end) end
        task.spawn(function() while State.InstantLuckyBlockEnabled do pcall(fixLuckyBlocks) task.wait(2) end end)
    end
    function Fn.stopInstantLuckyBlock()
        if State.LuckyBlockConnection then State.LuckyBlockConnection:Disconnect() State.LuckyBlockConnection=nil end
    end
end

-- ════════════════════════════════════════
-- // ARCADE SCANNER
-- ════════════════════════════════════════
do
    local function CreateArcadeVisuals()
        if State.arcadeScannerFolder then pcall(function() State.arcadeScannerFolder:Destroy() end) end
        State.arcadeScannerFolder=Instance.new("Folder") State.arcadeScannerFolder.Name="ArcadeScannerVisuals" State.arcadeScannerFolder.Parent=workspace.CurrentCamera
        local function mkP(name,color,transp,shape,size)
            local p=Instance.new("Part") p.Name=name p.Anchored=true p.CanCollide=false p.CastShadow=false
            p.Transparency=transp p.Material=Enum.Material.Neon p.Color=color
            if shape then p.Shape=shape end if size then p.Size=size end
            p.Parent=State.arcadeScannerFolder return p
        end
        State.arcadeRing=mkP("ArcadeRing",Color3.fromRGB(0,255,120),0.6,Enum.PartType.Cylinder,Vector3.new(0.1,State.ScanRadius*2,State.ScanRadius*2))
        State.arcadeInnerRing=mkP("ArcadeInnerRing",Color3.fromRGB(100,255,150),0.8,Enum.PartType.Cylinder,Vector3.new(0.1,State.ScanRadius*1.5,State.ScanRadius*1.5))
        State.arcadeScanLine=mkP("ArcadeScanLine",Color3.fromRGB(0,200,255),0.3,nil,Vector3.new(State.ScanRadius,0.2,0.5))
        State.arcadeCenterDot=mkP("ArcadeCenterDot",Color3.fromRGB(0,200,255),0.2,Enum.PartType.Ball,Vector3.new(1,1,1))
    end
    local function DestroyArcadeVisuals()
        if State.arcadeScannerFolder then pcall(function() State.arcadeScannerFolder:Destroy() end) State.arcadeScannerFolder=nil end
        State.arcadeRing=nil State.arcadeInnerRing=nil State.arcadeScanLine=nil State.arcadeCenterDot=nil
    end
    local function ArcadeHL(cp)
        if State.arcadeHighlights[cp] then return end
        local h=Instance.new("Highlight") h.FillColor=Color3.fromRGB(255,255,0) h.OutlineColor=Color3.fromRGB(255,200,0)
        h.FillTransparency=0.5 h.OutlineTransparency=0 h.Parent=cp State.arcadeHighlights[cp]=h
    end
    local function ArcadeRemHL(cp)
        if State.arcadeHighlights[cp] then State.arcadeHighlights[cp]:Destroy() State.arcadeHighlights[cp]=nil end
    end
    local function ArcadeCollect(cp,hrp)
        if not cp or not hrp or State.arcadeCollectedCoins[cp] then return end
        local ti=cp:FindFirstChild("TouchInterest") or cp:FindFirstChildWhichIsA("TouchTransmitter")
        if ti or cp:FindFirstChild("TouchInterest") then
            pcall(function() if firetouchinterest then firetouchinterest(cp,hrp,0) task.wait() firetouchinterest(cp,hrp,1) end end)
            State.arcadeCollectedCoins[cp]=true State.ArcadeCoinsCollected=State.ArcadeCoinsCollected+1
            task.delay(1,function() State.arcadeCollectedCoins[cp]=nil end)
        end
    end
    function Fn.StartArcadeScanner()
        if State.arcadeMainConnection then return end
        CreateArcadeVisuals()
        State.arcadeMainConnection=RunService.RenderStepped:Connect(function(dt)
            if not State.AutoArcadeScan then DestroyArcadeVisuals() if State.arcadeMainConnection then State.arcadeMainConnection:Disconnect() State.arcadeMainConnection=nil end return end
            local char=LP.Character; if not char then return end
            local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
            if not State.arcadeScannerFolder or not State.arcadeScannerFolder.Parent then CreateArcadeVisuals() end
            local rp=hrp.Position local gp=rp-Vector3.new(0,2.8,0)
            local rc=CFrame.new(gp)*CFrame.Angles(0,0,math.rad(90))
            if State.arcadeRing and State.arcadeRing.Parent then State.arcadeRing.CFrame=rc State.arcadeRing.Size=Vector3.new(0.1,State.ScanRadius*2,State.ScanRadius*2) end
            if State.arcadeInnerRing and State.arcadeInnerRing.Parent then State.arcadeInnerRing.CFrame=rc end
            if State.arcadeCenterDot and State.arcadeCenterDot.Parent then State.arcadeCenterDot.CFrame=CFrame.new(gp) end
            State.arcadeRotation=State.arcadeRotation+dt*2
            if State.arcadeScanLine and State.arcadeScanLine.Parent then State.arcadeScanLine.CFrame=CFrame.new(gp)*CFrame.Angles(0,State.arcadeRotation,0)*CFrame.new(State.ScanRadius/2,0,0) end
            State.arcadePulseValue=State.arcadePulseValue+dt*3
            local pulse=(math.sin(State.arcadePulseValue)+1)/2
            if State.arcadeInnerRing and State.arcadeInnerRing.Parent then State.arcadeInnerRing.Transparency=0.7+pulse*0.25 end
            if State.arcadeRing and State.arcadeRing.Parent then State.arcadeRing.Transparency=0.5+pulse*0.2 end
            if State.arcadeCenterDot and State.arcadeCenterDot.Parent then local s=1+pulse*0.5 State.arcadeCenterDot.Size=Vector3.new(s,s,s) end
            local ac=workspace:FindFirstChild("ArcadeEventConsoles")
            if ac then for _,item in pairs(ac:GetDescendants()) do if item:IsA("BasePart") then local isT=(item.Name=="Game console") or item:FindFirstChild("TouchInterest") if isT then local d=(item.Position-rp).Magnitude if d<=State.ScanRadius then ArcadeHL(item) ArcadeCollect(item,hrp) else ArcadeRemHL(item) end end end end end
        end)
    end
    function Fn.StopArcadeScanner()
        if State.arcadeMainConnection then State.arcadeMainConnection:Disconnect() State.arcadeMainConnection=nil end
        DestroyArcadeVisuals()
        for _,h in pairs(State.arcadeHighlights) do pcall(function() h:Destroy() end) end
        State.arcadeHighlights={}
    end
    LP.CharacterRemoving:Connect(function()
        for _,h in pairs(State.arcadeHighlights) do pcall(function() h:Destroy() end) end
        State.arcadeHighlights={}
    end)
end

-- ════════════════════════════════════════
-- // FIRE & ICE COIN SCANNER
-- ════════════════════════════════════════
do
    local function CreateFireIceVisuals()
        if State.fireIceFolder then pcall(function() State.fireIceFolder:Destroy() end) end
        State.fireIceFolder = Instance.new("Folder")
        State.fireIceFolder.Name = "FireIceScannerVisuals"
        State.fireIceFolder.Parent = workspace.CurrentCamera
        local function mkPart(name,color,transp,shape,size)
            local p=Instance.new("Part")
            p.Name=name p.Anchored=true p.CanCollide=false p.CastShadow=false
            p.Transparency=transp p.Material=Enum.Material.Neon p.Color=color
            if shape then p.Shape=shape end if size then p.Size=size end
            p.Parent=State.fireIceFolder return p
        end
        local R=State.ScanRadius
        State.fireIceOuterRing    = mkPart("FI_OuterRing",   C.FireIceFire, 0.55, Enum.PartType.Cylinder, Vector3.new(0.15,R*2,  R*2  ))
        State.fireIceInnerRing    = mkPart("FI_InnerRing",   C.FireIceIce,  0.70, Enum.PartType.Cylinder, Vector3.new(0.15,R*1.4,R*1.4))
        State.fireIceParticleRing = mkPart("FI_ParticleRing",C.FireIceMix,  0.82, Enum.PartType.Cylinder, Vector3.new(0.08,R*1.7,R*1.7))
        State.fireIceScanBeam     = mkPart("FI_ScanBeam1",   C.FireIceFire, 0.25, nil,                    Vector3.new(R,   0.35, 0.35 ))
        State.fireIceScanBeam2    = mkPart("FI_ScanBeam2",   C.FireIceIce,  0.25, nil,                    Vector3.new(R,   0.35, 0.35 ))
        State.fireIceCenterOrb    = mkPart("FI_CenterOrb",   C.FireIceMix,  0.15, Enum.PartType.Ball,     Vector3.new(1.2, 1.2,  1.2  ))
    end

    local function DestroyFireIceVisuals()
        if State.fireIceFolder then pcall(function() State.fireIceFolder:Destroy() end) State.fireIceFolder=nil end
        State.fireIceOuterRing=nil State.fireIceInnerRing=nil State.fireIceParticleRing=nil
        State.fireIceScanBeam=nil  State.fireIceScanBeam2=nil State.fireIceCenterOrb=nil
    end

    local function FIHighlight(cp)
        if State.fireIceHighlights[cp] then return end
        local h=Instance.new("Highlight")
        h.FillColor=C.FireIceMix h.OutlineColor=C.FireIceIce
        h.FillTransparency=0.45 h.OutlineTransparency=0 h.Parent=cp
        State.fireIceHighlights[cp]=h
    end

    local function FIRemoveHighlight(cp)
        if State.fireIceHighlights[cp] then State.fireIceHighlights[cp]:Destroy() State.fireIceHighlights[cp]=nil end
    end

    local function FICollect(cp,hrp)
        if not cp or not hrp then return end
        if State.fireIceCollectedCoins[cp] then return end
        local function tryFire(part)
            if part:FindFirstChild("TouchInterest") then
                pcall(function() if firetouchinterest then firetouchinterest(hrp,part,0) task.wait() firetouchinterest(hrp,part,1) end end)
                return true
            end
            for _,c in pairs(part:GetDescendants()) do
                if c:IsA("TouchTransmitter") or c.Name=="TouchInterest" then
                    pcall(function() if firetouchinterest then firetouchinterest(hrp,c.Parent,0) task.wait() firetouchinterest(hrp,c.Parent,1) end end)
                    return true
                end
            end
            return false
        end
        if tryFire(cp) then
            State.fireIceCollectedCoins[cp]=true
            State.FireIceCollected=State.FireIceCollected+1
            State.TotalCoinsCollected=State.TotalCoinsCollected+1
            task.delay(1.5,function() State.fireIceCollectedCoins[cp]=nil end)
        end
    end

    local function ScanFireIceCoins(hrp)
        local rootPos=hrp.Position
        local folder=workspace:FindFirstChild("FireAndIceEventParts")
        if not folder then return end
        for _,obj in pairs(folder:GetDescendants()) do
            local n=obj.Name:lower()
            local isCoin = n:find("fireandicecoin") or n:find("fire_and_ice_coin")
                        or n:find("fireicecoin")    or n=="coin"
            if isCoin then
                if obj:IsA("BasePart") or obj:IsA("MeshPart") then
                    local ok,d=pcall(function() return (obj.Position-rootPos).Magnitude end)
                    if ok then
                        if d<=State.ScanRadius then FIHighlight(obj) FICollect(obj,hrp)
                        else FIRemoveHighlight(obj) end
                    end
                elseif obj:IsA("Model") then
                    local part=obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                    if part then
                        local ok,d=pcall(function() return (part.Position-rootPos).Magnitude end)
                        if ok then
                            if d<=State.ScanRadius then FIHighlight(part) FICollect(part,hrp)
                            else FIRemoveHighlight(part) end
                        end
                    end
                end
            end
        end
    end

    function Fn.StartFireIceScanner()
        if State.fireIceMainConnection then return end
        CreateFireIceVisuals()
        State.fireIceMainConnection=RunService.RenderStepped:Connect(function(dt)
            if not State.AutoFireIceScan then
                DestroyFireIceVisuals()
                if State.fireIceMainConnection then State.fireIceMainConnection:Disconnect() State.fireIceMainConnection=nil end
                return
            end
            local char=LP.Character; if not char then return end
            local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
            if not State.fireIceFolder or not State.fireIceFolder.Parent then CreateFireIceVisuals() end
            local rootPos=hrp.Position
            local groundPos=rootPos-Vector3.new(0,2.5,0)
            local flatCF=CFrame.new(groundPos)*CFrame.Angles(0,0,math.rad(90))
            local R=State.ScanRadius
            if State.fireIceOuterRing    and State.fireIceOuterRing.Parent    then State.fireIceOuterRing.CFrame=flatCF    State.fireIceOuterRing.Size=Vector3.new(0.15,R*2,  R*2  ) end
            if State.fireIceInnerRing    and State.fireIceInnerRing.Parent    then State.fireIceInnerRing.CFrame=flatCF    State.fireIceInnerRing.Size=Vector3.new(0.15,R*1.4,R*1.4) end
            if State.fireIceParticleRing and State.fireIceParticleRing.Parent then State.fireIceParticleRing.CFrame=flatCF State.fireIceParticleRing.Size=Vector3.new(0.08,R*1.7,R*1.7) end
            State.fireIceRotation=State.fireIceRotation+dt*2.2
            if State.fireIceScanBeam  and State.fireIceScanBeam.Parent  then State.fireIceScanBeam.CFrame =CFrame.new(groundPos)*CFrame.Angles(0,State.fireIceRotation,0)*CFrame.new(R/2,0,0) end
            if State.fireIceScanBeam2 and State.fireIceScanBeam2.Parent then State.fireIceScanBeam2.CFrame=CFrame.new(groundPos)*CFrame.Angles(0,State.fireIceRotation+math.pi,0)*CFrame.new(R/2,0,0) end
            State.fireIcePulse=State.fireIcePulse+dt*2.8
            local pulse=(math.sin(State.fireIcePulse)+1)/2
            if State.fireIceOuterRing    and State.fireIceOuterRing.Parent    then State.fireIceOuterRing.Color=C.FireIceFire:Lerp(C.FireIceIce,pulse)    State.fireIceOuterRing.Transparency=0.5+pulse*0.2 end
            if State.fireIceInnerRing    and State.fireIceInnerRing.Parent    then State.fireIceInnerRing.Color=C.FireIceIce:Lerp(C.FireIceFire,pulse)     State.fireIceInnerRing.Transparency=0.65+(1-pulse)*0.2 end
            if State.fireIceParticleRing and State.fireIceParticleRing.Parent then State.fireIceParticleRing.Color=C.FireIceMix:Lerp(C.FireIceIce,pulse*0.5) State.fireIceParticleRing.Transparency=0.78+pulse*0.15 end
            if State.fireIceScanBeam     and State.fireIceScanBeam.Parent     then State.fireIceScanBeam.Color=C.FireIceFire:Lerp(Color3.new(1,1,1),pulse*0.3) end
            if State.fireIceScanBeam2    and State.fireIceScanBeam2.Parent    then State.fireIceScanBeam2.Color=C.FireIceIce:Lerp(Color3.new(1,1,1),(1-pulse)*0.3) end
            if State.fireIceCenterOrb    and State.fireIceCenterOrb.Parent    then
                State.fireIceCenterOrb.CFrame=CFrame.new(groundPos)
                local s=1.0+pulse*0.6 State.fireIceCenterOrb.Size=Vector3.new(s,s,s)
                State.fireIceCenterOrb.Color=C.FireIceFire:Lerp(C.FireIceIce,pulse)
                State.fireIceCenterOrb.Transparency=0.1+pulse*0.15
            end
        end)
        task.spawn(function()
            while State.AutoFireIceScan do
                local char=LP.Character
                if char then local hrp=char:FindFirstChild("HumanoidRootPart") if hrp then pcall(function() ScanFireIceCoins(hrp) end) end end
                task.wait(0.12)
            end
        end)
    end

    function Fn.StopFireIceScanner()
        if State.fireIceMainConnection then State.fireIceMainConnection:Disconnect() State.fireIceMainConnection=nil end
        DestroyFireIceVisuals()
        for _,h in pairs(State.fireIceHighlights) do pcall(function() h:Destroy() end) end
        State.fireIceHighlights={} State.fireIceCollectedCoins={}
    end

    LP.CharacterRemoving:Connect(function()
        for _,h in pairs(State.fireIceHighlights) do pcall(function() h:Destroy() end) end
        State.fireIceHighlights={} State.fireIceCollectedCoins={}
    end)
end

-- ════════════════════════════════════════
-- // GAP TELEPORT
-- ════════════════════════════════════════
do
    function Fn.TeleportToGap(n)
        local char=LP.Character; if not char then return false end
        local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return false end
        local maps={"DefaultMap_SharedInstances","DoomMap_SharedInstances","ValentinesMap_SharedInstances","ArcadeMap_SharedInstances","MarsMap_SharedInstances","DefaultMap","DoomMap","ValentinesMap","ArcadeMap","MarsMap"}
        local names={"Gap"..n,"Gap "..n,"gap"..n,"gap "..n,tostring(n)}
        local function tryTP(p)
            if not p then return false end
            local cf=p.CFrame+Vector3.new(0,5,0)
            if n<=5 then hrp.CFrame=cf
            else TweenService:Create(hrp,TweenInfo.new(math.clamp((hrp.Position-cf.Position).Magnitude/100,1,5),Enum.EasingStyle.Linear,Enum.EasingDirection.InOut),{CFrame=cf}):Play() end
            return true
        end
        local function getPart(o) if o:IsA("BasePart") then return o end if o:IsA("Model") then return o.PrimaryPart or o:FindFirstChildWhichIsA("BasePart") end return nil end
        for _,mn in ipairs(maps) do
            local m=workspace:FindFirstChild(mn)
            if m then
                local gf=m:FindFirstChild("Gaps") or m:FindFirstChild("gaps")
                if gf then for _,gn in ipairs(names) do local g=gf:FindFirstChild(gn) if g and tryTP(getPart(g)) then return true end end end
                for _,gn in ipairs(names) do for _,d in pairs(m:GetDescendants()) do if d.Name==gn and (d:IsA("BasePart") or d:IsA("Model")) then if tryTP(getPart(d)) then return true end end end end
            end
        end
        local rg=workspace:FindFirstChild("Gaps") or workspace:FindFirstChild("gaps")
        if rg then for _,gn in ipairs(names) do local g=rg:FindFirstChild(gn) if g and tryTP(getPart(g)) then return true end end end
        return false
    end
end

-- ════════════════════════════════════════
-- // GOD MODE FUNCTIONS
-- ════════════════════════════════════════
do
    local function GodGetChar()
        return LP.Character
    end
    local function GodGetHum()
        local c = GodGetChar()
        return c and c:FindFirstChildOfClass("Humanoid")
    end
    local function GodGetRoot()
        local c = GodGetChar()
        return c and c:FindFirstChild("HumanoidRootPart")
    end

    local function GodKillVertVel()
        local root = GodGetRoot()
        if not root then return end
        local vel = root.AssemblyLinearVelocity
        root.AssemblyLinearVelocity = Vector3.new(vel.X, 0, vel.Z)
    end

    local function GodDisableJump()
        local hum = GodGetHum()
        if not hum then return end
        GodState.savedJumpPower  = hum.JumpPower
        GodState.savedJumpHeight = hum.JumpHeight
        hum.JumpPower  = 0
        hum.JumpHeight = 0
        hum:SetStateEnabled(Enum.HumanoidStateType.Jumping,  false)
        hum:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
    end

    local function GodRestoreJump()
        local hum = GodGetHum()
        if not hum then return end
        hum.JumpPower  = GodState.savedJumpPower
        hum.JumpHeight = GodState.savedJumpHeight
        hum:SetStateEnabled(Enum.HumanoidStateType.Jumping,  true)
        hum:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
    end

    local function GodShowRealBody()
        local char = GodGetChar()
        if not char then return end
        for _,v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                v.LocalTransparencyModifier = 0
            elseif v:IsA("Decal") or v:IsA("Texture") then
                v.LocalTransparencyModifier = 0
            elseif v:IsA("BillboardGui") then
                v.Enabled = true
            end
        end
    end

    local function GodFixRootPosition()
        local root = GodGetRoot()
        if GodState.isDown and root and root.Parent then
            root.CFrame = root.CFrame - Vector3.new(0, GodState.DEPTH, 0)
            GodKillVertVel()
            GodState.isDown = false
        end
    end

    local function GodBuildFake(sourceChar)
        sourceChar.Archivable = true
        local clone = sourceChar:Clone()
        sourceChar.Archivable = false

        local h = clone:FindFirstChildOfClass("Humanoid")
        if h then h:Destroy() end

        for _,v in pairs(clone:GetDescendants()) do
            if v:IsA("BaseScript") or v:IsA("Sound") or v:IsA("Animator")
            or v:IsA("AnimationController") or v:IsA("Motor6D") or v:IsA("Weld")
            or v:IsA("WeldConstraint") or v:IsA("HingeConstraint") or v:IsA("BallSocketConstraint")
            or v:IsA("AlignPosition") or v:IsA("AlignOrientation") or v:IsA("BodyVelocity")
            or v:IsA("BodyForce") or v:IsA("BodyGyro") or v:IsA("BodyPosition")
            or v:IsA("VectorForce") or v:IsA("LinearVelocity") or v:IsA("AngularVelocity") then
                v:Destroy()
            end
        end

        for _,v in pairs(clone:GetDescendants()) do
            if v:IsA("BasePart") then
                v.Anchored   = true
                v.CanCollide = false
                v.CanTouch   = false
                v.CanQuery   = false
                v.Velocity   = Vector3.zero
            end
        end

        clone.Name   = "GodmodeBody"
        clone.Parent = workspace
        return clone
    end

    local function GodBuildPartMap(sourceChar, fakeChar)
        local map = {}
        for _,realPart in ipairs(sourceChar:GetDescendants()) do
            if realPart:IsA("BasePart") then
                local fakePart = fakeChar:FindFirstChild(realPart.Name, true)
                if fakePart and fakePart:IsA("BasePart") then
                    map[realPart] = fakePart
                end
            end
        end
        return map
    end

    -- Status label reference (set when tab is built)
    local godStatusLabel = nil
    local godStatusDot   = nil

    local function GodUpdateUI()
        if godStatusLabel and godStatusLabel.Parent then
            godStatusLabel.Text = GodState.enabled and "ACTIVE" or "DISABLED"
            godStatusLabel.TextColor3 = GodState.enabled and C.Green or C.Red
        end
        if godStatusDot and godStatusDot.Parent then
            Fn.Tween(godStatusDot, {BackgroundColor3 = GodState.enabled and C.Green or C.Red}, 0.2)
        end
    end

    function Fn.GodSetStatusRefs(lbl, dot)
        godStatusLabel = lbl
        godStatusDot   = dot
    end

    function Fn.EnableGodmode()
        local char = GodGetChar()
        local root = GodGetRoot()
        if not char or not root then return end

        GodState.enabled         = true
        GodState.isDown          = false
        GodState.savedPositions  = {}
        GodState.smoothY         = {}
        GodState.groundY         = root.CFrame.Position.Y
        GodState.fakeGroundY     = GodState.groundY
        GodState.fakeJumpOffset  = 0
        GodState.fakeJumpVelocity= 0

        GodDisableJump()

        if GodState.fake and GodState.fake.Parent then GodState.fake:Destroy() end
        GodState.fake    = GodBuildFake(char)
        GodState.partMap = GodBuildPartMap(char, GodState.fake)

        local fakeRoot = GodState.fake:FindFirstChild("HumanoidRootPart")
        if fakeRoot then Camera.CameraSubject = fakeRoot end

        -- Stepped: bring up + freeze Y
        if GodState.steppedConn then GodState.steppedConn:Disconnect() end
        GodState.steppedConn = RunService.Stepped:Connect(function()
            if not GodState.enabled then return end
            local rt = GodGetRoot(); if not rt then return end
            local hum2 = GodGetHum()
            if hum2 then hum2.JumpPower=0 hum2.JumpHeight=0 end
            GodKillVertVel()
            if GodState.isDown then
                local currentCF = rt.CFrame
                local pos = currentCF.Position
                rt.CFrame = currentCF - Vector3.new(0, pos.Y - GodState.groundY, 0)
                GodKillVertVel()
                GodState.isDown = false
            end
        end)

        -- Heartbeat: save positions + push down
        if GodState.heartbeatConn then GodState.heartbeatConn:Disconnect() end
        GodState.heartbeatConn = RunService.Heartbeat:Connect(function()
            if not GodState.enabled then return end
            local rt = GodGetRoot(); if not rt then return end
            if GodState.isDown then return end
            GodKillVertVel()
            GodState.groundY = rt.CFrame.Position.Y
            GodState.savedPositions = {}
            for realPart,_ in pairs(GodState.partMap) do
                if realPart and realPart.Parent then
                    GodState.savedPositions[realPart] = realPart.CFrame
                end
            end
            local currentCF = rt.CFrame
            rt.CFrame = currentCF + Vector3.new(0, GodState.DEPTH, 0)
            GodKillVertVel()
            GodState.isDown = true
        end)

        -- RenderStepped: fake body + infinite jump + hide real body
        if GodState.renderConn then GodState.renderConn:Disconnect() end
        GodState.renderConn = RunService.RenderStepped:Connect(function(dt)
            if not GodState.enabled then return end
            local char2 = GodGetChar(); if not char2 then return end
            if not GodState.fake or not GodState.fake.Parent then return end

            -- Simulate infinite jump physics
            if GodState.fakeJumpOffset > 0 or GodState.fakeJumpVelocity ~= 0 then
                GodState.fakeJumpVelocity = GodState.fakeJumpVelocity - GodState.FAKE_GRAVITY * dt
                GodState.fakeJumpOffset   = GodState.fakeJumpOffset + GodState.fakeJumpVelocity * dt
                if GodState.fakeJumpOffset <= 0 then
                    GodState.fakeJumpOffset   = 0
                    GodState.fakeJumpVelocity = 0
                end
            end

            local rt = GodGetRoot()
            -- Position fake parts
            for realPart, fakePart in pairs(GodState.partMap) do
                local saved = GodState.savedPositions[realPart]
                if saved and fakePart and fakePart.Parent then
                    local pos  = saved.Position
                    local rot  = saved - pos
                    local finalY = GodState.groundY + GodState.fakeJumpOffset
                    if realPart.Name ~= "HumanoidRootPart" and rt then
                        local rootSaved = GodState.savedPositions[rt]
                        if rootSaved then
                            local offsetY = pos.Y - rootSaved.Position.Y
                            finalY = GodState.groundY + offsetY + GodState.fakeJumpOffset
                        end
                    end
                    fakePart.CFrame   = rot + Vector3.new(pos.X, finalY, pos.Z)
                    fakePart.Anchored = true
                end
            end

            -- Hide real body
            for _,v in pairs(char2:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.LocalTransparencyModifier = 1
                elseif v:IsA("Decal") or v:IsA("Texture") then
                    v.LocalTransparencyModifier = 1
                elseif v:IsA("BillboardGui") then
                    v.Enabled = false
                end
            end
        end)

        -- Jump connection: infinite jump
        if GodState.jumpConn then GodState.jumpConn:Disconnect() end
        GodState.jumpConn = UserInputService.JumpRequest:Connect(function()
            if GodState.enabled then
                GodState.fakeJumpVelocity = GodState.FAKE_JUMP_POWER
            end
        end)

        GodUpdateUI()
        print("[God Mode] ON")
    end

    function Fn.DisableGodmode()
        GodState.enabled = false

        GodFixRootPosition()

        if GodState.steppedConn   then GodState.steppedConn:Disconnect()   GodState.steppedConn=nil   end
        if GodState.heartbeatConn then GodState.heartbeatConn:Disconnect()  GodState.heartbeatConn=nil end
        if GodState.renderConn    then GodState.renderConn:Disconnect()     GodState.renderConn=nil    end
        if GodState.jumpConn      then GodState.jumpConn:Disconnect()       GodState.jumpConn=nil      end

        if GodState.fake and GodState.fake.Parent then GodState.fake:Destroy() end
        GodState.fake            = nil
        GodState.partMap         = {}
        GodState.savedPositions  = {}
        GodState.smoothY         = {}
        GodState.groundY         = nil
        GodState.fakeGroundY     = 0
        GodState.fakeJumpOffset  = 0
        GodState.fakeJumpVelocity= 0
        GodState.isDown          = false

        GodShowRealBody()
        GodRestoreJump()

        local hum = GodGetHum()
        if hum then Camera.CameraSubject = hum end

        GodUpdateUI()
        print("[God Mode] OFF")
    end

    function Fn.ToggleGodmode()
        if GodState.enabled then Fn.DisableGodmode() else Fn.EnableGodmode() end
    end

    -- Keyboard toggle (K key)
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == GodState.TOGGLE_KEY then
            Fn.ToggleGodmode()
        end
    end)

    -- Respawn handler
    LP.CharacterAdded:Connect(function(newChar)
        local wasEnabled = GodState.enabled

        if GodState.steppedConn   then GodState.steppedConn:Disconnect()   GodState.steppedConn=nil   end
        if GodState.heartbeatConn then GodState.heartbeatConn:Disconnect()  GodState.heartbeatConn=nil end
        if GodState.renderConn    then GodState.renderConn:Disconnect()     GodState.renderConn=nil    end
        if GodState.jumpConn      then GodState.jumpConn:Disconnect()       GodState.jumpConn=nil      end

        if GodState.fake and GodState.fake.Parent then GodState.fake:Destroy() end
        GodState.fake            = nil
        GodState.partMap         = {}
        GodState.isDown          = false
        GodState.savedPositions  = {}
        GodState.smoothY         = {}
        GodState.enabled         = false
        GodState.groundY         = nil
        GodState.fakeGroundY     = 0
        GodState.fakeJumpOffset  = 0
        GodState.fakeJumpVelocity= 0

        task.wait(1)
        local hum = newChar:FindFirstChildOfClass("Humanoid")
        if hum then
            GodState.savedJumpPower  = hum.JumpPower
            GodState.savedJumpHeight = hum.JumpHeight
        end

        if wasEnabled then
            Fn.EnableGodmode()
        else
            GodUpdateUI()
        end
    end)
end

