-- ============================================================
local RARITY_ORDER  = {"common","uncommon","rare","epic","legendary","mythic","mythical","secret","divine","celestial","cosmic"}
local RARITY_COLORS = {
    common=Color3.fromRGB(180,180,180), uncommon=Color3.fromRGB(80,200,80),
    rare=Color3.fromRGB(60,120,255),    epic=Color3.fromRGB(180,60,255),
    legendary=Color3.fromRGB(255,180,0),mythic=Color3.fromRGB(255,50,50),
    mythical=Color3.fromRGB(255,80,80), secret=Color3.fromRGB(255,0,100),
    divine=Color3.fromRGB(255,220,100), celestial=Color3.fromRGB(180,255,255), cosmic=Color3.fromRGB(120,200,255),
}

local function getRarityColor(n)
    local lo = string.lower(n)
    for _, kw in ipairs(RARITY_ORDER) do if lo:find(kw) then return RARITY_COLORS[kw] end end
    return Color3.fromRGB(200,200,200)
end

local RARITY_KW_SET = {
    "common","uncommon","rare","epic","legendary",
    "mythic","mythical","secret","divine","celestial","cosmic"
}

local function isRarityName(name)
    if not name then return false end
    local lo = string.lower(name)
    for _, kw in ipairs(RARITY_KW_SET) do
        if lo == kw or lo:find(kw, 1, true) then return true end
    end
    return false
end

local function scanBrainrotFolders()
    local f = {}
    for _,c in pairs(CFG.BRAINROT_PATH:GetChildren()) do
        if (c:IsA("Folder") or c:IsA("Model")) and isRarityName(c.Name) then
            table.insert(f, c.Name)
        end
    end
    table.sort(f); return f
end

local function getBrainrots(sel)
    local b = {}
    for _,rn in pairs(sel) do
        local fo = CFG.BRAINROT_PATH:FindFirstChild(rn)
        if fo then
            for _,br in pairs(fo:GetChildren()) do
                local p = br:IsA("Model") and (br.PrimaryPart or br:FindFirstChildWhichIsA("BasePart"))
                       or (br:IsA("BasePart") and br or nil)
                if p then table.insert(b, {Name=br.Name, Rarity=rn, Part=p, Object=br}) end
            end
        end
    end
    return b
end

-- ── Lucky Block rarity: brute-force scan everything on the object ──
local function extractRarityFromString(s)
    if not s or #s == 0 then return nil end
    local lo = string.lower(s)
    for _,kw in ipairs(RARITY_ORDER) do
        if lo:find(kw, 1, true) then
            return kw:sub(1,1):upper()..kw:sub(2)
        end
    end
    return nil
end

local function extractLBRarity(obj)
    if type(obj) == "string" then return extractRarityFromString(obj) end
    if not obj then return nil end
    local r

    local function tryStr(s) return s and extractRarityFromString(tostring(s)) or nil end

    -- 1. Object name
    r = tryStr(obj.Name); if r then return r end

    -- 2. All attributes on the object
    local ok, attrs = pcall(function() return obj:GetAttributes() end)
    if ok and attrs then
        for k,v in pairs(attrs) do
            r = tryStr(v); if r then return r end
            r = tryStr(k); if r then return r end
        end
    end

    -- 3. Every single descendant
    for _,d in pairs(obj:GetDescendants()) do
        r = tryStr(d.Name); if r then return r end
        if d:IsA("StringValue") or d:IsA("IntValue") then
            local ok2,val = pcall(function() return d.Value end)
            if ok2 then r = tryStr(val); if r then return r end end
        end
        if d:IsA("TextLabel") or d:IsA("TextButton") then
            local ok2,txt = pcall(function() return d.Text end)
            if ok2 then r = tryStr(txt); if r then return r end end
        end
        local dok, dattrs = pcall(function() return d:GetAttributes() end)
        if dok and dattrs then
            for k,v in pairs(dattrs) do
                r = tryStr(v); if r then return r end
                r = tryStr(k); if r then return r end
            end
        end
    end

    return nil
end

local function getLuckyBlocksDeep(selR)
    local b = {}
    local function scanObj(obj)
        local r = extractLBRarity(obj)
        if r and selR[r] then
            local p = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart"))
                   or (obj:IsA("BasePart") and obj or nil)
            if p then table.insert(b, {Name=obj.Name, Rarity=r, Part=p, Object=obj}); return end
        end
        for _,c in pairs(obj:GetChildren()) do
            if c:IsA("Folder") or c:IsA("Model") then scanObj(c) end
        end
    end
    for _,c in pairs(CFG.LUCKYBLOCK_PATH:GetChildren()) do
        scanObj(c)
    end
    return b
end

local function getTargetsSorted()
    local targets
    if ST.activeSubTab == "Brainrot" then
        local sel = {}
        for n in pairs(ST.brainrotSelectedRarities) do table.insert(sel, n) end
        targets = #sel > 0 and getBrainrots(sel) or {}
    else
        targets = getLuckyBlocksDeep(ST.luckyBlockSelectedRarities)
    end
    if CFG.CLOSEST_FIRST and rootPart and rootPart.Parent then
        local pos = rootPart.Position
        table.sort(targets, function(a,b)
            local da = a.Part and a.Part.Parent and (a.Part.Position-pos).Magnitude or math.huge
            local db = b.Part and b.Part.Parent and (b.Part.Position-pos).Magnitude or math.huge
            return da < db
        end)
    end
    return targets
end

local function hasSelections()
    if ST.activeSubTab == "Brainrot" then
        for _ in pairs(ST.brainrotSelectedRarities) do return true end
    else
        for _ in pairs(ST.luckyBlockSelectedRarities) do return true end
    end
    return false
end

