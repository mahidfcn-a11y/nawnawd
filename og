-- ============================================================
-- ============================================================
-- TRIAL LOOP
-- ============================================================
local function doOneTrialRun()
    ST.trialInProgress = true; ST.trialGrabbed = 0; ST.trialCollecting = false
    resetTracker(); clearFloors(); updateFloorLabel(); saveSelections()

    -- ── 1. Travel to tower (same depth pattern as smartTravelTo) ──
    if LBL.TrialStatus then LBL.TrialStatus.Text = "Going to tower..."; LBL.TrialStatus.TextColor3 = Color3.fromRGB(255,200,0) end
    local arrived = travelToTower()
    if not arrived or not isAlive() then
        restoreSelections(); restoreFloors(); updateFloorLabel(); ST.trialInProgress = false
        if LBL.TrialStatus then LBL.TrialStatus.Text = "Couldn't reach tower"; LBL.TrialStatus.TextColor3 = Color3.fromRGB(255,80,80) end
        return false, "dead"
    end
    task.wait(0.3)

    -- ── 2. Check cooldown ─────────────────────────────────────────
    if isTrialOnCooldown() then
        if LBL.TrialStatus then LBL.TrialStatus.Text = "Trial on cooldown"; LBL.TrialStatus.TextColor3 = Color3.fromRGB(255,80,80) end
        restoreSelections(); restoreFloors(); updateFloorLabel(); ST.trialInProgress = false
        return false, "cooldown"
    end

    -- ── 3. Activate trial if not already running ──────────────────
    if not isTrialTimerActive() then
        if LBL.TrialStatus then LBL.TrialStatus.Text = "Activating trial..."; LBL.TrialStatus.TextColor3 = Color3.fromRGB(255,200,0) end
        fireTrialPrompt(); task.wait(0.4)
        fireTrialPrompt(); task.wait(0.4)
        fireTrialPrompt(); task.wait(2.0)  -- wait for billboard to update
    else
        task.wait(0.5)
    end

    -- ── 4. Read billboard rarity ──────────────────────────────────
    if LBL.TrialStatus then LBL.TrialStatus.Text = "Reading billboard..."; LBL.TrialStatus.TextColor3 = Color3.fromRGB(0,200,255) end
    local dr, dc = nil, nil
    for attempt = 1, 12 do
        if not ST.autoTrialEnabled then break end
        dr, dc = readInfoDirect()
        if dr then break end
        if LBL.Log then LBL.Log.Text = "Scanning billboard " .. attempt .. "/12" end
        task.wait(0.5)
    end
    if not dr then dr, dc = scanWithRetry(6, 0.4) end
    if not dr then
        restoreSelections(); restoreFloors(); updateFloorLabel(); ST.trialInProgress = false
        if LBL.TrialStatus then LBL.TrialStatus.Text = "No rarity found"; LBL.TrialStatus.TextColor3 = Color3.fromRGB(255,80,80) end
        return false, "no_rarity"
    end

    local fn = matchRarityFolder(dr)
    if not fn then
        restoreSelections(); restoreFloors(); updateFloorLabel(); ST.trialInProgress = false
        if LBL.TrialStatus then LBL.TrialStatus.Text = "No folder: " .. dr; LBL.TrialStatus.TextColor3 = Color3.fromRGB(255,80,80) end
        return false, "no_folder"
    end

    ST.currentTrialRarity = dr; ST.currentTrialFolder = fn
    ST.trialRequired = dc or 1; ST.trialCollecting = true
    autoSelectTrialRarity(fn); updateTrackerLabel(); startContinuousTracker()
    if LBL.TrialStatus then LBL.TrialStatus.Text = string.format("Need %d %s", ST.trialRequired, fn); LBL.TrialStatus.TextColor3 = Color3.fromRGB(0,255,100) end
    if LBL.TrialDetail  then LBL.TrialDetail.Text  = string.format("Folder: %s | Req: %d", fn, ST.trialRequired); LBL.TrialDetail.TextColor3 = Color3.fromRGB(0,200,255) end

    -- ── 5. Collect & deliver loop ─────────────────────────────────
    local ts = tick()
    while ST.autoTrialEnabled and (tick() - ts) < CFG.TRIAL_TIME_LIMIT do
        if not isAlive() then task.wait(0.5); continue end
        refreshChar(); checkMapChange(); updateTrackerLabel()

        -- Trial finished check
        if not isTrialTimerActive() then
            local r2 = readInfoDirect()
            if not r2 then
                stopContinuousTracker(); restoreSelections(); restoreFloors(); updateFloorLabel()
                ST.trialInProgress = false; ST.trialCollecting = false
                if LBL.TrialStatus then LBL.TrialStatus.Text = "Trial complete!"; LBL.TrialStatus.TextColor3 = Color3.fromRGB(0,255,100) end
                return true, "completed"
            end
        end

        -- Find closest brainrot of required rarity
        local avail = getBrainrots({ST.currentTrialFolder})
        if #avail == 0 then
            if LBL.Phase then LBL.Phase.Text = "Waiting for brainrots..." end
            task.wait(1); continue
        end
        if rootPart and rootPart.Parent then
            local pos = rootPart.Position
            table.sort(avail, function(a, b)
                local da = a.Part and a.Part.Parent and (a.Part.Position - pos).Magnitude or math.huge
                local db = b.Part and b.Part.Parent and (b.Part.Position - pos).Magnitude or math.huge
                return da < db
            end)
        end
        local tg = nil
        for _, t in ipairs(avail) do
            if t.Part and t.Part.Parent and t.Object and t.Object.Parent then tg = t; break end
        end
        if not tg then task.wait(0.5); continue end
        if not ST.autoTrialEnabled then break end

        local objectRef = tg.Object
        local targetPos = tg.Part.CFrame.Position
        if LBL.Phase  then LBL.Phase.Text  = "→ " .. tg.Name end
        if LBL.Status then LBL.Status.Text = "[" .. tg.Rarity .. "] " .. tg.Name end

        -- Wave safety
        if ST.waveCheckEnabled and isWaveNear(targetPos, CFG.WAVE_SAFE_DISTANCE) then
            waitWaveClear(targetPos, function(m) if LBL.Phase then LBL.Phase.Text = m end end)
            if not ST.autoTrialEnabled then break end
        end

        -- Travel to brainrot — use returnTweenToken (isReturn=true) so it
        -- cannot be stomped by activeTweenToken or towerTweenToken
        local ok = smartTravelTo(targetPos, CFG.GRAB_HEIGHT, false, true)
        if not ok or not isAlive() then task.wait(0.3); continue end
        if not ST.autoTrialEnabled then break end
        if not objectRef or not objectRef.Parent then continue end

        local livePart = objectRef:IsA("Model") and (objectRef.PrimaryPart or objectRef:FindFirstChildWhichIsA("BasePart"))
                      or (objectRef:IsA("BasePart") and objectRef or nil)
        if not livePart or not livePart.Parent then continue end

        local preGrabPos = livePart.Position
        if LBL.Phase then LBL.Phase.Text = "Grabbing!" end
        fullGrab(objectRef, livePart, livePart.Position); task.wait(0.5)
        if not isAlive() then task.wait(0.3); continue end

        -- Grab success check
        local grabbed = false
        if not objectRef or not objectRef.Parent then grabbed = true
        elseif not objectRef.Parent:IsDescendantOf(CFG.BRAINROT_PATH) then grabbed = true
        elseif livePart and livePart.Parent and (livePart.Position - preGrabPos).Magnitude > 5 then grabbed = true end
        if not grabbed then
            if LBL.Phase then LBL.Phase.Text = "Miss, retrying..." end
            task.wait(0.2); continue
        end

        ST.trialGrabbed += 1; ST.totalGrabbed += 1
        if LBL.Grabbed       then LBL.Grabbed.Text       = "Grabbed: " .. ST.totalGrabbed end
        if LBL.TrialProgress then LBL.TrialProgress.Text = string.format("Progress: %d/%d", ST.trialGrabbed, ST.trialRequired) end

        -- Deliver: travel back to tower using same depth travel
        if LBL.Phase then LBL.Phase.Text = "↓ Delivering..." end
        if LBL.TrialStatus then LBL.TrialStatus.Text = "Delivering to tower..."; LBL.TrialStatus.TextColor3 = Color3.fromRGB(255,200,0) end
        local delivered = travelToTower()
        if not delivered or not isAlive() then task.wait(0.3); continue end

        task.wait(0.2)
        fireTrialPrompt(); task.wait(0.3)
        fireTrialPrompt(); task.wait(0.3)
        fireTrialPrompt(); task.wait(0.4)
        if not ST.autoTrialEnabled then break end

        -- Re-read billboard after delivery
        local nr, nc = readInfoDirect()
        if not nr then
            stopContinuousTracker(); restoreSelections(); restoreFloors(); updateFloorLabel()
            ST.trialInProgress = false; ST.trialCollecting = false
            if LBL.TrialStatus then LBL.TrialStatus.Text = "Trial complete!"; LBL.TrialStatus.TextColor3 = Color3.fromRGB(0,255,100) end
            return true, "completed"
        end
        local nf = matchRarityFolder(nr)
        if nf and nf ~= ST.currentTrialFolder then
            ST.previousTrialRarity = ST.currentTrialRarity; ST.currentTrialRarity = nr
            ST.currentTrialFolder = nf; ST.trialRequired = nc or 1; ST.rarityChangeCount += 1
            autoSelectTrialRarity(nf)
            if LBL.TrialStatus then LBL.TrialStatus.Text = string.format("Changed! Need %d %s", nc or 1, nf); LBL.TrialStatus.TextColor3 = Color3.fromRGB(255,200,0) end
        elseif nf then
            ST.trialRequired = nc or ST.trialRequired
            if LBL.TrialStatus then LBL.TrialStatus.Text = string.format("Need %d %s", ST.trialRequired, nf); LBL.TrialStatus.TextColor3 = Color3.fromRGB(0,255,100) end
        end
        updateTrackerLabel(); task.wait(0.1)
    end

    stopContinuousTracker(); restoreSelections(); restoreFloors(); updateFloorLabel()
    ST.trialInProgress = false; ST.trialCollecting = false
    return true, "timeout"
end

function _startAutoTrialLoop()
    if ST.autoTrialRunning then return end
    ST.autoTrialEnabled = true; ST.autoTrialRunning = true
    if not ST.savedCFrame then
        if rootPart and rootPart.Parent then ST.savedCFrame = rootPart.CFrame; updateSavedPosLabel() end
    end
    if LBL.TrialStatus then LBL.TrialStatus.Text = "Trial: ACTIVE"; LBL.TrialStatus.TextColor3 = Color3.fromRGB(0,200,255) end
    enableNoclip(); lockPhysics()
    while ST.autoTrialEnabled do
        local ok, reason = doOneTrialRun()
        stopContinuousTracker(); restoreFloors(); updateFloorLabel()
        if not ST.autoTrialEnabled then break end
        if reason == "cooldown" then
            -- poll until cooldown actually clears
            if LBL.TrialStatus then LBL.TrialStatus.Text = "Waiting for cooldown..."; LBL.TrialStatus.TextColor3 = Color3.fromRGB(150,150,150) end
            repeat task.wait(2) until not isTrialOnCooldown() or not ST.autoTrialEnabled
        elseif reason == "no_rarity" or reason == "no_folder" or reason == "dead" then
            if LBL.TrialStatus then LBL.TrialStatus.Text = "Retrying in 3s..."; LBL.TrialStatus.TextColor3 = Color3.fromRGB(255,150,0) end
            task.wait(3)
        else
            -- completed / timeout: wait between runs
            for i = CFG.TRIAL_COOLDOWN_WAIT, 1, -1 do
                if not ST.autoTrialEnabled then break end
                if LBL.TrialStatus then LBL.TrialStatus.Text = string.format("Next run in %ds...", i); LBL.TrialStatus.TextColor3 = Color3.fromRGB(150,150,150) end
                task.wait(1)
            end
        end
    end
    ST.autoTrialRunning = false; stopContinuousTracker(); restoreFloors(); updateFloorLabel()
    if not ST.running then unlockPhysics(); disableNoclip() end
    if LBL.TrialStatus then LBL.TrialStatus.Text = "Trial: OFF"; LBL.TrialStatus.TextColor3 = Color3.fromRGB(180,180,180) end
end

