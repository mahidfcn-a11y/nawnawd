-- ============================================================
-- TWEEN ENGINE  (token-based, race-condition-free)
-- ============================================================
ST.activeTweenToken = nil
ST.returnTweenToken = nil
ST.towerTweenToken  = nil
local tweenTokenCounter = 0

local function newToken()
    tweenTokenCounter += 1
    return tweenTokenCounter
end

local function doTween(targetCF, speed, ease, allowReturn)
    if not rootPart or not rootPart.Parent then return false end
    if ST.respawning or not isAlive() then return false end
    if not allowReturn and not ST.running and not ST.autoTrialEnabled then return false end

    local myToken = newToken()
    if allowReturn then
        ST.returnTweenToken = myToken
    else
        ST.activeTweenToken = myToken
    end

    local dist = (rootPart.Position - targetCF.Position).Magnitude
    if dist < 0.5 then forceCF(targetCF); return true end

    local dur = math.max(dist / speed, 0.02)
    local startCF = rootPart.CFrame
    local startT  = tick()

    ST.tweening        = true
    ST.tweenFrameCount = 0
    ST.waveEmergencyDive = false

    if ST.bodyVel  and ST.bodyVel.Parent  then ST.bodyVel.MaxForce  = Vector3.zero end
    if ST.bodyGyro and ST.bodyGyro.Parent then ST.bodyGyro.MaxTorque = Vector3.zero end

    local function easeF(a)
        if ease == 1 then return 0.5 - 0.5*math.cos(a*math.pi)
        elseif ease == 2 then return 1 - (1-a)*(1-a) end
        return a
    end

    local running = true
    while running do
        if not isAlive() then ST.tweening = false; return false end

        if allowReturn then
            if ST.returnTweenToken ~= myToken then ST.tweening = false; freeze(); return false end
        else
            if ST.activeTweenToken ~= myToken then ST.tweening = false; freeze(); return false end
        end

        local el = tick() - startT
        local ra = math.clamp(el / dur, 0, 1)
        local a  = easeF(ra)

        ST.tweenFrameCount += 1
        forceCF(startCF:Lerp(targetCF, a))
        pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Physics) end)

        if LBL.Speed and ST.tweenFrameCount % 5 == 0 then
            LBL.Speed.Text = string.format("%.0f studs | %.1fs", dist*(1-ra), math.max(0, dur-el))
        end

        if CFG.MID_TWEEN_WAVE_CHECK and ST.waveCheckEnabled and ST.tweenFrameCount % CFG.WAVE_CHECK_FRAMES == 0 then
            if isWaveNear(rootPart.Position, CFG.WAVE_SAFE_DISTANCE * 0.6) then
                ST.tweening = false; ST.waveEmergencyDive = true; freeze(); return false
            end
        end

        if ra >= 1 then break end
        RunService.Heartbeat:Wait()
    end

    ST.tweening = false
    forceCF(targetCF)
    freeze()
    return true
end

local function stopTween()
    ST.activeTweenToken = nil
    ST.tweening = false
end

local function stopAllTweens()
    ST.activeTweenToken = nil
    ST.returnTweenToken = nil
    ST.towerTweenToken  = nil
    ST.tweening = false
end

-- Return-only tween: used exclusively by stopAndReturn.
-- Has its own token, cannot be cancelled by farming or tower tweens.
local function doTweenReturn(targetCF, speed, ease)
    if not rootPart or not rootPart.Parent then return false end
    if ST.respawning then return false end
    -- only runs while ST.stopping is true
    if not ST.stopping then return false end

    local myToken = newToken()
    ST.returnTweenToken = myToken

    local dist = (rootPart.Position - targetCF.Position).Magnitude
    if dist < 0.5 then return true end

    local dur     = math.max(dist / speed, 0.02)
    local startCF = rootPart.CFrame
    local startT  = tick()

    ST.tweening = true
    if ST.bodyVel  and ST.bodyVel.Parent  then ST.bodyVel.MaxForce   = Vector3.zero end
    if ST.bodyGyro and ST.bodyGyro.Parent then ST.bodyGyro.MaxTorque = Vector3.zero end

    local function easeF(a)
        if ease == 1 then return 0.5 - 0.5*math.cos(a*math.pi)
        elseif ease == 2 then return 1 - (1-a)*(1-a) end
        return a
    end

    while true do
        if not rootPart or not rootPart.Parent then ST.tweening = false; return false end
        if ST.returnTweenToken ~= myToken then ST.tweening = false; freeze(); return false end
        if not ST.stopping then ST.tweening = false; freeze(); return false end

        local el = tick() - startT
        local ra = math.clamp(el / dur, 0, 1)
        forceCF(startCF:Lerp(targetCF, easeF(ra)))
        pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Physics) end)
        if ra >= 1 then break end
        RunService.Heartbeat:Wait()
    end

    ST.tweening = false
    forceCF(targetCF)
    freeze()
    return true
end

-- Tower-only tween: uses its own token, cannot be cancelled by stopTween()
-- or by the farming loop stomping activeTweenToken.
local function doTweenTower(targetCF, speed, ease)
    if not rootPart or not rootPart.Parent then return false end
    if ST.respawning or not isAlive() then return false end
    if not ST.autoTrialEnabled then return false end

    local myToken = newToken()
    ST.towerTweenToken = myToken

    local dist = (rootPart.Position - targetCF.Position).Magnitude
    if dist < 0.5 then forceCF(targetCF); return true end

    local dur      = math.max(dist / speed, 0.02)
    local startCF  = rootPart.CFrame
    local startT   = tick()

    ST.tweening = true
    if ST.bodyVel  and ST.bodyVel.Parent  then ST.bodyVel.MaxForce   = Vector3.zero end
    if ST.bodyGyro and ST.bodyGyro.Parent then ST.bodyGyro.MaxTorque = Vector3.zero end

    local function easeF(a)
        if ease == 1 then return 0.5 - 0.5*math.cos(a*math.pi)
        elseif ease == 2 then return 1 - (1-a)*(1-a) end
        return a
    end

    while true do
        if not isAlive() then ST.tweening = false; return false end
        if ST.towerTweenToken ~= myToken then ST.tweening = false; freeze(); return false end
        if not ST.autoTrialEnabled then ST.tweening = false; freeze(); return false end

        local el = tick() - startT
        local ra = math.clamp(el / dur, 0, 1)
        forceCF(startCF:Lerp(targetCF, easeF(ra)))
        pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Physics) end)
        if ra >= 1 then break end
        RunService.Heartbeat:Wait()
    end

    ST.tweening = false
    forceCF(targetCF)
    freeze()
    return true
end

-- ============================================================
-- SMART TWEEN TRAVEL  (dive → horizontal → rise)
-- ============================================================
local function smartTravelTo(targetPos, grabH, skipWave, isReturn)
    if not rootPart or not rootPart.Parent then return false end
    if not isAlive() then return false end
    grabH = grabH or 0

    if LBL.Phase then LBL.Phase.Text = "↓ Diving..." end
    local myPos = rootPart.Position
    if not doTween(CFrame.new(myPos.X, myPos.Y + CFG.TRAVEL_DEPTH, myPos.Z), CFG.DIVE_SPEED, 2, isReturn) then
        return false
    end
    if not isAlive() then return false end

    if LBL.Phase then LBL.Phase.Text = "→ Traveling..." end
    if not doTween(CFrame.new(targetPos.X, targetPos.Y + CFG.TRAVEL_DEPTH, targetPos.Z), CFG.TWEEN_SPEED, 0, isReturn) then
        return false
    end
    if not isAlive() then return false end

    if not skipWave and ST.waveCheckEnabled and isWaveNear(targetPos, CFG.WAVE_SAFE_DISTANCE) then
        waitWaveClear(targetPos, function(m) if LBL.Phase then LBL.Phase.Text = m end end)
        if not isAlive() then return false end
    end

    if LBL.Phase then LBL.Phase.Text = "↑ Rising..." end
    if not doTween(CFrame.new(targetPos.X, targetPos.Y + grabH, targetPos.Z), CFG.RISE_SPEED, 2, isReturn) then
        return false
    end
    return true
end

local function travelToTower()
    refreshChar(); enableNoclip(); lockPhysics()
    if not rootPart or not rootPart.Parent or not isAlive() then return false end

    local tp    = CFG.TOWER_CFRAME.Position
    local myPos = rootPart.Position
    local depth = CFG.TRAVEL_DEPTH  -- negative value, e.g. -30

    -- Phase 1: dive underground from current pos
    if LBL.Phase then LBL.Phase.Text = "↓ Diving to tower..." end
    if not doTweenTower(CFrame.new(myPos.X, myPos.Y + depth, myPos.Z), CFG.DIVE_SPEED, 2) then return false end
    if not isAlive() then return false end

    -- Phase 2: travel horizontally underground straight to tower XZ
    if LBL.Phase then LBL.Phase.Text = "→ Flying to tower..." end
    if not doTweenTower(CFrame.new(tp.X, tp.Y + depth, tp.Z), CFG.TWEEN_SPEED, 0) then return false end
    if not isAlive() then return false end

    -- Phase 3: rise up to tower prompt level
    if LBL.Phase then LBL.Phase.Text = "↑ Arriving at tower..." end
    if not doTweenTower(CFrame.new(tp.X, tp.Y + 3, tp.Z), CFG.RISE_SPEED, 2) then return false end

    return isAlive()
end

-- ============================================================
-- PROXIMITY PROMPT TRIGGER
-- ============================================================
local function firePrompt(prompt)
    if not prompt or not prompt:IsA("ProximityPrompt") then return end
    local oh  = prompt.HoldDuration
    local od  = prompt.MaxActivationDistance
    local oe  = prompt.Enabled
    local ox  = prompt.Exclusivity

    prompt.HoldDuration          = 0
    prompt.MaxActivationDistance = CFG.PROMPT_OVERRIDE_DISTANCE
    prompt.Enabled               = true
    prompt.Exclusivity           = Enum.ProximityPromptExclusivity.AlwaysShow

    pcall(function() prompt:InputHoldBegin() end)
    pcall(function() prompt:InputHoldEnd()   end)
    pcall(function() ProximityPromptService:TriggerPrompt(prompt) end)

    task.delay(0.1, function()
        if prompt and prompt.Parent then
            prompt.HoldDuration          = oh
            prompt.MaxActivationDistance = od
            prompt.Enabled               = oe
            prompt.Exclusivity           = ox
        end
    end)
end

local function fireTrialPrompt()
    local p = getProximityPrompt(); if not p then return false end
    firePrompt(p)
    return true
end

local function grabAllPrompts(obj)
    if not obj or not obj.Parent then return end
    local fired = {}
    local function once(p)
        if not p or not p:IsA("ProximityPrompt") or fired[p] then return end
        fired[p] = true
        firePrompt(p)
    end
    if obj:IsA("ProximityPrompt") then once(obj) end
    for _,d in pairs(obj:GetDescendants()) do once(d) end
    task.wait(0.05)
    for p in pairs(fired) do
        pcall(function() p:InputHoldBegin() end)
        pcall(function() p:InputHoldEnd()   end)
    end
end

local function grabNearbyPrompts(pos, rad)
    rad = rad or 20
    local list = {}
    for _,d in pairs(workspace:GetDescendants()) do
        if d:IsA("ProximityPrompt") and d.Parent and d.Parent:IsA("BasePart") then
            local dist = (d.Parent.Position - pos).Magnitude
            if dist <= rad then table.insert(list, {p=d, dist=dist}) end
        end
    end
    table.sort(list, function(a,b) return a.dist < b.dist end)
    for _,e in ipairs(list) do firePrompt(e.p) end
    task.wait(0.05)
    for _,e in ipairs(list) do
        if e.p and e.p.Parent then
            pcall(function() e.p:InputHoldBegin() end)
            pcall(function() e.p:InputHoldEnd()   end)
        end
    end
end

local function fullGrab(obj, part, pos)
    if not obj or not obj.Parent or not isAlive() then return end

    if part and part.Parent and rootPart and rootPart.Parent then
        local grabCF = part.CFrame * CFrame.new(0, 1.5, 0)
        if ST.bodyVel and ST.bodyVel.Parent then ST.bodyVel.MaxForce = Vector3.zero end
        doTween(grabCF, CFG.RISE_SPEED * 2, 1, true)
        if ST.bodyVel and ST.bodyVel.Parent then
            ST.bodyVel.MaxForce  = Vector3.new(1e9,1e9,1e9)
            ST.bodyVel.Velocity  = Vector3.zero
        end
    end

    task.wait(0.03)
    grabAllPrompts(obj)
    grabNearbyPrompts(pos or (part and part.Position or Vector3.zero), 18)

    pcall(function()
        for _,d in pairs(obj:GetDescendants()) do
            if d:IsA("ClickDetector") then
                pcall(function() fireclickdetector(d) end)
            end
        end
    end)

    task.wait(0.05)
    grabAllPrompts(obj)
    grabNearbyPrompts(pos or (part and part.Position or Vector3.zero), 18)
end

local function enableAutoInstant()
    ST.autoInstantEnabled = true
    for _,d in pairs(workspace:GetDescendants()) do
        if d:IsA("ProximityPrompt") then
            d.HoldDuration = 0
            d.MaxActivationDistance = math.max(d.MaxActivationDistance, 15)
        end
    end
    ST.promptConnections[#ST.promptConnections+1] = workspace.DescendantAdded:Connect(function(d)
        if ST.autoInstantEnabled and d:IsA("ProximityPrompt") then
            task.wait()
            d.HoldDuration = 0
            d.MaxActivationDistance = math.max(d.MaxActivationDistance, 15)
        end
    end)
end

local function disableAutoInstant()
    ST.autoInstantEnabled = false
    for _,c in pairs(ST.promptConnections) do c:Disconnect() end
    ST.promptConnections = {}
end

