do
    function Fn.GetRarityColor(r) return RarityColors[r] or RarityColors["Default"] end

    function Fn.GetRealBrainrotName(b)
        local rb = b:FindFirstChild("RenderBrainrot")
        if rb then return rb.Name end
        for _,c in pairs(b:GetChildren()) do
            if c:IsA("Model") and c.Name~="HumanoidRootPart" and c.Name~="Head" then return c.Name end
        end
        local nv = b:FindFirstChild("BrainrotName") or b:FindFirstChild("DisplayName")
        if nv and nv:IsA("StringValue") and nv.Value~="" then return nv.Value end
        local an = b:GetAttribute("BrainrotName") or b:GetAttribute("DisplayName")
        if an then return an end
        return b.Name
    end

    function Fn.IsESPSelected(folder, name)
        if SelectedFolders[folder]==true then return true end
        if SelectedBrainrots[folder.."/"..name]==true then return true end
        return false
    end

    function Fn.NothingESPSelected()
        for _,v in pairs(SelectedFolders) do if v then return false end end
        for _,v in pairs(SelectedBrainrots) do if v then return false end end
        return true
    end

    function Fn.ClearAllESP()
        for k in pairs(SelectedFolders) do SelectedFolders[k]=nil end
        for k in pairs(SelectedBrainrots) do SelectedBrainrots[k]=nil end
        for _,d in pairs(ESPObjects) do
            if d.esp then
                for _,l in pairs(d.esp.BoxLines or {}) do pcall(function() l.Visible=false end) end
                pcall(function() d.esp.Name.Visible=false end)
                pcall(function() d.esp.Rarity.Visible=false end)
                pcall(function() d.esp.Distance.Visible=false end)
                pcall(function() d.esp.Tracer.Visible=false end)
            end
        end
    end

    function Fn.ScanBrainrotFolders()
        local AB = workspace:FindFirstChild("ActiveBrainrots")
        if not AB then return {} end
        local s = {}
        for _,c in pairs(AB:GetChildren()) do
            if c:IsA("Folder") then
                s[c.Name]={}
                for _,b in pairs(c:GetChildren()) do
                    if b:IsA("Model") then
                        table.insert(s[c.Name], {modelName=b.Name, realName=Fn.GetRealBrainrotName(b)})
                    end
                end
            elseif c:IsA("Model") then
                if not s["Uncategorized"] then s["Uncategorized"]={} end
                table.insert(s["Uncategorized"], {modelName=c.Name, realName=Fn.GetRealBrainrotName(c)})
            end
        end
        return s
    end
end

