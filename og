local function getTsunamiDist(pos)
    if not CFG.TSUNAMI_PATH or not CFG.TSUNAMI_PATH.Parent then return math.huge end
    local cl=math.huge
    for _,o in pairs(CFG.TSUNAMI_PATH:GetDescendants()) do
        if o:IsA("BasePart") then local d=(o.Position-pos).Magnitude; if d<cl then cl=d end end end
    return cl
end

local function isWaveNear(pos,sd) return getTsunamiDist(pos)<(sd or CFG.WAVE_SAFE_DISTANCE) end

local function waitWaveClear(tp,cb)
    local st=tick()
    while true do
        if getTsunamiDist(tp)<CFG.WAVE_SAFE_DISTANCE then
            if cb then cb("Wave nearby...") end
            task.wait(CFG.WAVE_CHECK_INTERVAL)
            if tick()-st>CFG.WAVE_MAX_WAIT then return true end
            if not ST.running and not ST.autoTrialRunning then return false end
        else return true end
    end
end

local function updateWaveLabel()
    if not LBL.Wave then return end
    local pos = rootPart and rootPart.Parent and rootPart.Position or Vector3.zero
    local d = getTsunamiDist(pos)
    if d<CFG.WAVE_SAFE_DISTANCE then LBL.Wave.Text="⚠ WAVE! ("..math.floor(d)..")"; LBL.Wave.TextColor3=Color3.fromRGB(255,60,60)
    elseif d<CFG.WAVE_SAFE_DISTANCE*2 then LBL.Wave.Text="Wave near ("..math.floor(d)..")"; LBL.Wave.TextColor3=Color3.fromRGB(255,200,60)
    else LBL.Wave.Text="Waves: Safe"; LBL.Wave.TextColor3=Color3.fromRGB(100,255,100) end
end

