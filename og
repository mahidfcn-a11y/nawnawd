local function findFloorsFolder()
    for _, c in pairs(workspace:GetChildren()) do
        if string.find(c.Name,"SharedInstances") or string.find(c.Name,"_Shared") then
            local f = c:FindFirstChild("Floors")
            if f then return f, c.Name end
