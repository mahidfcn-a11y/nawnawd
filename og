local RARITY_KW = {"cosmic","celestial","divine","secret","mythical","mythic","legendary","epic","rare","uncommon","common"}

local function extractRarity(text)
    if not text or #text==0 then return nil,nil end
    local lo = string.lower(text)
    if lo:match("time remaining") or lo:match("cooldown") or lo:match("seconds left") then return nil,nil end
    if lo:match("^%s*%d+%s*$") or lo:match("^%s*%d+:%d") then return nil,nil end
    for _, kw in ipairs(RARITY_KW) do
        if lo:find(kw,1,true) then
            local c = tonumber(lo:match("(%d+)%s*x?%s*"..kw)) or
                      tonumber(lo:match(kw.."%s*[x:%-]?%s*(%d+)")) or
                      tonumber(lo:match("[%(%[](%d+)[%)%]]")) or
                      tonumber(lo:match("x(%d+)"))
            if not c then for n in lo:gmatch("(%d+)") do local v=tonumber(n); if v and v>=1 and v<=99 then c=v; break end end end
            return kw, c or 1
        end
    end
    return nil,nil
end

local function getInfoFrame()
    local ok,i = pcall(function() return workspace.GameObjects.PlaceSpecific.root.Tower.Main.Billboard.BillboardGui.Frame.Info end)
    return ok and i or nil
end

local function readInfoDirect()
    local info = getInfoFrame(); if not info or not info.Parent then return nil,nil,nil end
    local best, bestPri = nil, 999
    for _, d in pairs(info:GetDescendants()) do
        if (d:IsA("TextLabel") or d:IsA("TextButton") or d:IsA("TextBox")) then
            local text = d.Text; if not text or #text<2 then continue end
            local lo = string.lower(text)
            local inTimer = false; local par = d.Parent
            while par and par ~= info do
                local pn = string.lower(par.Name)
                if pn:find("timer") or pn:find("cooldown") or pn:find("countdown") then inTimer=true; break end
                par = par.Parent
            end
            if inTimer then continue end
            if lo:match("^%s*%d+%s*$") or lo:match("^%s*%d+:%d") or lo:match("^%s*%d+s%s*$") then continue end
            if lo:find("time remaining",1,true) or lo:find("cooldown",1,true) then continue end
            local r,c = extractRarity(text)
            if r then
                local pri = 50
                if lo:find("bring",1,true) then pri=1 elseif lo:find("collect",1,true) then pri=2
                elseif lo:find("deliver",1,true) then pri=3 elseif lo:find("need",1,true) then pri=4
                elseif lo:find("brainrot",1,true) then pri=8 end
                if pri < bestPri then bestPri=pri; best={r=r,c=c,t=text} end
            end
        end
    end
    if best then return best.r, best.c, best.t end
    return nil,nil,nil
end

local function scanTrialBillboard()
    local r,c,t = readInfoDirect(); if r then return r,c,t end
    local pg = player:FindFirstChild("PlayerGui"); if not pg then return nil,nil,nil end
    local bm, bp = nil, 999
    for _, d in pairs(pg:GetDescendants()) do
        if (d:IsA("TextLabel") or d:IsA("TextButton")) and d.Visible then
            local text=d.Text; if not text or #text<2 then continue end
            local lo=string.lower(text)
            local isTR = lo:find("trial") or lo:find("bring") or lo:find("collect") or lo:find("tsunami") or lo:find("deliver") or (lo:find("need") and lo:find("brainrot"))
            if not isTR then local p=d.Parent; while p and p~=pg do local pn=string.lower(p.Name)
                if pn:find("trial") or pn:find("tsunami") or pn:find("tower") or pn:find("quest") then isTR=true; break end; p=p.Parent end end
            if isTR then local rv,cv=extractRarity(text)
                if rv then local pri=50
                    if lo:find("bring",1,true) then pri=1 elseif lo:find("collect",1,true) then pri=2
                    elseif lo:find("deliver",1,true) then pri=3 elseif lo:find("need",1,true) then pri=4 end
                    if pri<bp then bp=pri; bm={r=rv,c=cv} end end end
        end
    end
    if bm then return bm.r, bm.c, nil end
    return nil,nil,nil
end

local function scanWithRetry(ma,db)
    ma=ma or 6; db=db or 0.3
    local res = {}
    for i=1,ma do
        if not ST.autoTrialEnabled then return nil,nil,nil end
        local r,c = scanTrialBillboard()
        if r then res[r]=(res[r] or 0)+1; if res[r]>=2 then return r,c end end
        if i<ma then task.wait(db) end
    end
    for i=1,4 do local r,c=scanTrialBillboard(); if r then return r,c end; task.wait(0.2) end
    return nil,nil
end

