-- Build Fake Character
local function buildDesyncFake(sourceChar)
    sourceChar.Archivable = true
    local clone = sourceChar:Clone()
    sourceChar.Archivable = false

    local h = clone:FindFirstChildOfClass("Humanoid")
    if h then h:Destroy() end

    for _, v in pairs(clone:GetDescendants()) do
        if v:IsA("BaseScript") or v:IsA("Sound") or v:IsA("Animator") or v:IsA("AnimationController")
        or v:IsA("Motor6D") or v:IsA("Weld") or v:IsA("WeldConstraint") or v:IsA("HingeConstraint")
        or v:IsA("BallSocketConstraint") or v:IsA("AlignPosition") or v:IsA("AlignOrientation")
        or v:IsA("BodyVelocity") or v:IsA("BodyForce") or v:IsA("BodyGyro") or v:IsA("BodyPosition")
        or v:IsA("VectorForce") or v:IsA("LinearVelocity") or v:IsA("AngularVelocity") then
            v:Destroy()
        end
    end

    for _, v in pairs(clone:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Anchored = true
            v.CanCollide = false
            v.CanTouch = false
            v.CanQuery = false
            v.Velocity = Vector3.zero
        end
    end

    clone.Name = "DesyncBody"
    clone.Parent = workspace
    return clone
end

local function buildDesyncPartMap(sourceChar, fakeChar)
    local map = {}
    for _, realPart in ipairs(sourceChar:GetDescendants()) do
        if realPart:IsA("BasePart") then
            local fakePart = fakeChar:FindFirstChild(realPart.Name, true)
            if fakePart and fakePart:IsA("BasePart") then
                map[realPart] = fakePart
            end
        end
    end
    return map
end

local function StartDesync()
    local char = LP.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    desyncFake = buildDesyncFake(char)
    desyncPartMap = buildDesyncPartMap(char, desyncFake)

    local fakeRoot = desyncFake:FindFirstChild("HumanoidRootPart")
    if fakeRoot then
        Camera.CameraSubject = fakeRoot
    end

    -- STEPPED: BRING UP + KEEP VELOCITY
    desyncConnections.stepped = RunService.Stepped:Connect(function()
        if not root or not root.Parent then return end
        if isDown then
            local vel = root.AssemblyLinearVelocity
            local angVel = root.AssemblyAngularVelocity
            root.CFrame = root.CFrame - Vector3.new(0, DEPTH, 0)
            root.AssemblyLinearVelocity = vel
            root.AssemblyAngularVelocity = angVel
            isDown = false
        end
    end)

    -- HEARTBEAT: SAVE + PUSH DOWN + KEEP VELOCITY
    desyncConnections.heartbeat = RunService.Heartbeat:Connect(function()
        if not root or not root.Parent then return end
        if isDown then return end

        savedPositions = {}
        for realPart, _ in pairs(desyncPartMap) do
            if realPart and realPart.Parent then
                savedPositions[realPart] = realPart.CFrame
            end
        end

        local vel = root.AssemblyLinearVelocity
        local angVel = root.AssemblyAngularVelocity
        root.CFrame = root.CFrame + Vector3.new(0, DEPTH, 0)
        root.AssemblyLinearVelocity = vel
        root.AssemblyAngularVelocity = angVel
        isDown = true
    end)

    -- RENDERSTEP: SMOOTH FAKE BODY + HIDE REAL
    desyncConnections.render = RunService.RenderStepped:Connect(function()
        if not char or not char.Parent then return end
        if not desyncFake or not desyncFake.Parent then return end

        for realPart, fakePart in pairs(desyncPartMap) do
            local saved = savedPositions[realPart]
            if saved and fakePart and fakePart.Parent then
                local pos = saved.Position
                local rot = saved - pos

                if not smoothY[realPart] then
                    smoothY[realPart] = pos.Y
                end

                local diff = math.abs(pos.Y - smoothY[realPart])

                if diff > math.abs(DEPTH) - 1 and diff < math.abs(DEPTH) + 1 then
                    -- Desync bounce, ignore
                else
                    smoothY[realPart] = pos.Y
                end

                fakePart.CFrame = rot + Vector3.new(pos.X, smoothY[realPart], pos.Z)
                fakePart.Anchored = true
            end
        end

        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                v.LocalTransparencyModifier = 1
            elseif v:IsA("Decal") or v:IsA("Texture") then
                v.LocalTransparencyModifier = 1
            elseif v:IsA("BillboardGui") then
                v.Enabled = false
            end
        end
    end)
end

local function StopDesync()
    for _, conn in pairs(desyncConnections) do
        if conn then conn:Disconnect() end
    end
    desyncConnections = {}

    if desyncFake and desyncFake.Parent then
        desyncFake:Destroy()
    end
    desyncFake = nil
    desyncPartMap = {}
    savedPositions = {}
    smoothY = {}
    isDown = false

    local char = LP.Character
    if char then
        Camera.CameraSubject = char:FindFirstChild("Humanoid")
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                v.LocalTransparencyModifier = 0
            elseif v:IsA("Decal") or v:IsA("Texture") then
                v.LocalTransparencyModifier = 0
            elseif v:IsA("BillboardGui") then
                v.Enabled = true
            end
        end
    end
end

