-- // FPS COUNTER SYSTEM
-- ════════════════════════════════════════
local FPSCounter = {
    CurrentFPS = 0,
    FrameTimes = {},
    MaxSamples = 60,
}

local function UpdateFPS()
    local currentTime = tick()
    table.insert(FPSCounter.FrameTimes, 1, currentTime)
    while #FPSCounter.FrameTimes > FPSCounter.MaxSamples do
        table.remove(FPSCounter.FrameTimes)
    end
    if #FPSCounter.FrameTimes >= 2 then
        local timeDiff = FPSCounter.FrameTimes[1] - FPSCounter.FrameTimes[#FPSCounter.FrameTimes]
        if timeDiff > 0 then
            FPSCounter.CurrentFPS = math.floor((#FPSCounter.FrameTimes - 1) / timeDiff)
        end
    end
end

