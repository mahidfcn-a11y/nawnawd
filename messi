local function ArcadeCollectCoin(coinPart, hrp)
    if not coinPart or not hrp then return end
    if arcadeCollectedCoins[coinPart] then return end
    
    local touchInterest = coinPart:FindFirstChild("TouchInterest")
        or coinPart:FindFirstChildWhichIsA("TouchTransmitter")
    
    if touchInterest or coinPart:FindFirstChild("TouchInterest") then
        pcall(function()
            if firetouchinterest then
                firetouchinterest(coinPart, hrp, 0)
                task.wait()
                firetouchinterest(coinPart, hrp, 1)
            end
        end)
        arcadeCollectedCoins[coinPart] = true
        ArcadeCoinsCollected = ArcadeCoinsCollected + 1
        task.delay(1, function()
            arcadeCollectedCoins[coinPart] = nil
        end)
    end
end

local function ArcadeHighlightCoin(coinPart)
    if arcadeHighlights[coinPart] then return end
    local highlight = Instance.new("Highlight")
    highlight.FillColor = Color3.fromRGB(255, 255, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 200, 0)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.Parent = coinPart
    arcadeHighlights[coinPart] = highlight
end

local function ArcadeRemoveHighlight(coinPart)
    if arcadeHighlights[coinPart] then
        arcadeHighlights[coinPart]:Destroy()
        arcadeHighlights[coinPart] = nil
    end
end

local function StartArcadeScanner()
    if arcadeMainConnection then return end
    CreateArcadeScannerVisuals()
    
    arcadeMainConnection = RunService.RenderStepped:Connect(function(dt)
        if not AutoArcadeScan then
            DestroyArcadeScannerVisuals()
            if arcadeMainConnection then arcadeMainConnection:Disconnect() arcadeMainConnection = nil end
            return
        end
        
        local char = LP.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        if not arcadeScannerFolder or not arcadeScannerFolder.Parent then
            CreateArcadeScannerVisuals()
        end
        
        local rootPos = hrp.Position
        local groundPos = rootPos - Vector3.new(0, 2.8, 0)
        
        local ringCFrame = CFrame.new(groundPos) * CFrame.Angles(0, 0, math.rad(90))
        if arcadeRing and arcadeRing.Parent then
            arcadeRing.CFrame = ringCFrame
            arcadeRing.Size = Vector3.new(0.1, ScanRadius * 2, ScanRadius * 2)
        end
        if arcadeInnerRing and arcadeInnerRing.Parent then
            arcadeInnerRing.CFrame = ringCFrame
        end
        if arcadeCenterDot and arcadeCenterDot.Parent then
            arcadeCenterDot.CFrame = CFrame.new(groundPos)
        end
        
        arcadeRotation = arcadeRotation + dt * 2
        if arcadeScanLine and arcadeScanLine.Parent then
            arcadeScanLine.CFrame = CFrame.new(groundPos) 
                * CFrame.Angles(0, arcadeRotation, 0) 
                * CFrame.new(ScanRadius / 2, 0, 0)
        end
        
        arcadePulseValue = arcadePulseValue + dt * 3
        local pulse = (math.sin(arcadePulseValue) + 1) / 2
        if arcadeInnerRing and arcadeInnerRing.Parent then
            arcadeInnerRing.Transparency = 0.7 + pulse * 0.25
        end
        if arcadeRing and arcadeRing.Parent then
            arcadeRing.Transparency = 0.5 + pulse * 0.2
        end
        if arcadeCenterDot and arcadeCenterDot.Parent then
            arcadeCenterDot.Size = Vector3.new(1 + pulse * 0.5, 1 + pulse * 0.5, 1 + pulse * 0.5)
        end
        
        -- Scan ArcadeEventConsoles
        local arcadeConsoles = workspace:FindFirstChild("ArcadeEventConsoles")
        if arcadeConsoles then
            for _, item in pairs(arcadeConsoles:GetDescendants()) do
                if item:IsA("BasePart") then
                    local isTarget = (item.Name == "Game console") or item:FindFirstChild("TouchInterest")
                    if isTarget then
                        local distance = (item.Position - rootPos).Magnitude
                        if distance <= ScanRadius then
                            ArcadeHighlightCoin(item)
                            ArcadeCollectCoin(item, hrp)
                        else
                            ArcadeRemoveHighlight(item)
                        end
                    end
                end
            end
        end
    end)
end

