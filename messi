-- Gap teleport function with tween for gaps 6-9
local function TeleportToGap(gapNumber)
    local char = LP.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- Search all possible map locations for gaps
    local mapNames = {
        "DefaultMap_SharedInstances",
        "DoomMap_SharedInstances",
        "ValentinesMap_SharedInstances",
        "ArcadeMap_SharedInstances",
        "MarsMap_SharedInstances",
        "DefaultMap",
        "DoomMap",
        "ValentinesMap",
        "ArcadeMap",
        "MarsMap",
    }
    
    -- Possible gap name formats
    local gapNames = {
        "Gap" .. gapNumber,
        "Gap " .. gapNumber,
        "gap" .. gapNumber,
        "gap " .. gapNumber,
        tostring(gapNumber),
    }
    
    -- Search in Gaps folder inside each map
    for _, mapName in ipairs(mapNames) do
        local map = workspace:FindFirstChild(mapName)
        if map then
            -- Look for Gaps folder
            local gapsFolder = map:FindFirstChild("Gaps") or map:FindFirstChild("gaps")
            if gapsFolder then
                for _, gName in ipairs(gapNames) do
                    local gap = gapsFolder:FindFirstChild(gName)
                    if gap then
                        local targetPart = nil
                        if gap:IsA("BasePart") then
                            targetPart = gap
                        elseif gap:IsA("Model") then
                            targetPart = gap.PrimaryPart or gap:FindFirstChildWhichIsA("BasePart")
                        end
                        if targetPart then
                            local targetCFrame = targetPart.CFrame + Vector3.new(0, 5, 0)
                            
                            -- Gaps 1-5: Instant teleport
                            if gapNumber <= 5 then
                                hrp.CFrame = targetCFrame
                            -- Gaps 6-9: Tween teleport
                            else
                                local distance = (hrp.Position - targetCFrame.Position).Magnitude
                                local tweenTime = math.clamp(distance / 100, 1, 5) -- 1-5 seconds based on distance
                                
                                local tween = TweenService:Create(hrp, TweenInfo.new(
                                    tweenTime,
                                    Enum.EasingStyle.Linear,
                                    Enum.EasingDirection.InOut
                                ), {CFrame = targetCFrame})
                                
                                tween:Play()
                            end
                            return true
                        end
                    end
                end
            end
            
            -- Also search directly in map descendants for gap names
            for _, gName in ipairs(gapNames) do
                for _, desc in pairs(map:GetDescendants()) do
                    if desc.Name == gName and (desc:IsA("BasePart") or desc:IsA("Model")) then
                        local targetPart = nil
                        if desc:IsA("BasePart") then
                            targetPart = desc
                        elseif desc:IsA("Model") then
                            targetPart = desc.PrimaryPart or desc:FindFirstChildWhichIsA("BasePart")
                        end
                        if targetPart then
                            local targetCFrame = targetPart.CFrame + Vector3.new(0, 5, 0)
                            
                            -- Gaps 1-5: Instant teleport
                            if gapNumber <= 5 then
                                hrp.CFrame = targetCFrame
                            -- Gaps 6-9: Tween teleport
                            else
                                local distance = (hrp.Position - targetCFrame.Position).Magnitude
                                local tweenTime = math.clamp(distance / 100, 1, 5)
                                
                                local tween = TweenService:Create(hrp, TweenInfo.new(
                                    tweenTime,
                                    Enum.EasingStyle.Linear,
                                    Enum.EasingDirection.InOut
                                ), {CFrame = targetCFrame})
                                
                                tween:Play()
                            end
                            return true
                        end
                    end
                end
            end
        end
    end
    
    -- Search workspace root for Gaps folder
    local rootGaps = workspace:FindFirstChild("Gaps") or workspace:FindFirstChild("gaps")
    if rootGaps then
        for _, gName in ipairs(gapNames) do
            local gap = rootGaps:FindFirstChild(gName)
            if gap then
                local targetPart = nil
                if gap:IsA("BasePart") then
                    targetPart = gap
                elseif gap:IsA("Model") then
                    targetPart = gap.PrimaryPart or gap:FindFirstChildWhichIsA("BasePart")
                end
                if targetPart then
                    local targetCFrame = targetPart.CFrame + Vector3.new(0, 5, 0)
                    
                    -- Gaps 1-5: Instant teleport
                    if gapNumber <= 5 then
                        hrp.CFrame = targetCFrame
                    -- Gaps 6-9: Tween teleport
                    else
                        local distance = (hrp.Position - targetCFrame.Position).Magnitude
                        local tweenTime = math.clamp(distance / 100, 1, 5)
                        
                        local tween = TweenService:Create(hrp, TweenInfo.new(
                            tweenTime,
                            Enum.EasingStyle.Linear,
                            Enum.EasingDirection.InOut
                        ), {CFrame = targetCFrame})
                        
                        tween:Play()
                    end
                    return true
                end
            end
        end
    end
    
    return false
end
